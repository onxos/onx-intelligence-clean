# ============================================================
# ONX INTELLIGENCE v1.0 — Environment Configuration
# ============================================================

# Database
DATABASE_URL=sqlite:///app.db

# OpenAI API Key (for Titan Bridge + Model Federation)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic Claude (optional — for model federation)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini (optional — for model federation)
GEMINI_API_KEY=your-gemini-key-here

# Zhipu GLM (optional — for model federation)
ZHIPU_API_KEY=your-zhipu-key-here

# Alibaba Qwen (optional — for model federation)
QWEN_API_KEY=your-qwen-key-here

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Owner Union ID
OWNER_UNION_ID=your-owner-union-id

# Application URL (for password reset links)
APP_URL=http://localhost:3000

# Node Environment
NODE_ENV=development

# Port (optional — defaults to 3000)
PORT=3000
