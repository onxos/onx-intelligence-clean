# ONX Intelligence Service — Environment Variables
# Copy to .env and fill in values

# Required
APP_ID=onx-intelligence
APP_SECRET=change-me-min-32-chars-xxxxxxxxxxxxx

# Bridge (Platform ↔ Intelligence)
BRIDGE_ENABLED=false                    # Set to 'true' to enable
BRIDGE_SHARED_SECRET=                   # Min 32 chars, must match platform BRIDGE_SHARED_SECRET

# Database
DATABASE_URL=sqlite:///app/db/onx-pilot.db

# AI Providers (optional — falls back to mock if not set)
KIMI_AUTH_URL=https://auth.kimi.com
KIMI_OPEN_URL=https://open.kimi.com
OWNER_UNION_ID=
OPENAI_API_KEY=

# Environment
NODE_ENV=development

# --- Data residency (C-4) ---
# Declares the deployment/data region explicitly so residency is auditable.
# Approved values: ksa-central (default, in-Kingdom), ksa-riyadh,
# me-central-1, me-south-1. A non-approved value is rejected/loudly warned.
# The actual infrastructure region is pinned in render.yaml / the hosting
# dashboard; this value must match it. See DEPLOYMENT_GUIDE.md.
DATA_REGION=ksa-central

# --- Webhook integration secrets (H-5) ---
# Fail-closed: when an integration is switched on with <NAME>_ENABLED=true
# in production, its secret MUST be set or the server refuses to start
# (signature verification can never silently fail open). Leave *_ENABLED
# unset/false for integrations you are not using.
# TWILIO_ENABLED=false
TWILIO_AUTH_TOKEN=
# STRIPE_ENABLED=false
STRIPE_WEBHOOK_SECRET=
# SQUARE_ENABLED=false
SQUARE_WEBHOOK_SIGNATURE_KEY=

# --- Operator tooling only (NOT read by the running server) ---
# Used exclusively by `npm run ingest:corpus -- <docs.json> --persist`
# (STE-K-16) to push authentic docs through the fail-closed bridge.
# Never committed with real values; provided by the operator at run time.
ONX_HOST=                               # e.g. https://onx-intelligence-clean.onrender.com
ONX_BRIDGE_KEY=                         # must equal the deployed BRIDGE_SHARED_SECRET

# Used exclusively by `npm run smoke:live` (scripts/smoke-live.ts) — the live
# smoke harness. The running server never reads these; they only shape which
# origin the operator measures and what the harness asserts.
GATEWAY_ORIGIN=                         # STE-K-20: e.g. https://onx-gateway.onrender.com — base becomes {origin}/intelligence (the measured full-app mount)
EXPECT_RL_PERSISTENCE=                  # STE-K-19: e.g. POSTGRES_PERSISTED — assert the deployment's rate-limit backing store
PARITY_BASE_URL=                        # STE-K-58: optional direct base for gateway/direct core parity (commit/count/fingerprint)
