/// Tracks every schema change (add/modify/drop/index) for governance and audit.
model SchemaEvolutionLog {
  id               String   @id @default(cuid())
  tableName        String   @map("table_name")
  columnName       String   @map("column_name")
  changeType       String   @map("change_type") // ADD, MODIFY, DROP, INDEX, EVOLUTION_EVENT
  oldDefinition    Json?    @map("old_definition")
  newDefinition    Json?    @map("new_definition")
  migrationScript  String?  @map("migration_script")
  appliedBy        String   @map("applied_by")
  workspaceId      String   @map("workspace_id")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([tableName])
  @@index([changeType])
  @@index([createdAt])
  @@map("schema_evolution_log")
}

/// Per-table usage statistics feeding the Zeus auto-optimizer.
model TableStatistics {
  id             String    @id @default(cuid())
  tableName      String    @map("table_name")
  rowCount       Int       @default(0) @map("row_count")
  avgQueryTimeMs Decimal?  @map("avg_query_time_ms") @db.Decimal(10, 2)
  indexHitRatio  Decimal?  @map("index_hit_ratio") @db.Decimal(5, 4)
  lastVacuumed   DateTime? @map("last_vacuumed")
  lastAnalyzed   DateTime? @map("last_analyzed")
  workspaceId    String    @map("workspace_id")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@unique([workspaceId, tableName])
  @@index([workspaceId])
  @@map("table_statistics")
}

/// Per-column usage analytics feeding schema intelligence recommendations.
model ColumnAnalytics {
  id             String   @id @default(cuid())
  tableName      String   @map("table_name")
  columnName     String   @map("column_name")
  nullPercentage Decimal? @map("null_percentage") @db.Decimal(5, 2)
  distinctRatio  Decimal? @map("distinct_ratio") @db.Decimal(5, 4)
  avgValueSize   Int?     @map("avg_value_size")
  queryFrequency Int      @default(0) @map("query_frequency")
  workspaceId    String   @map("workspace_id")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([workspaceId, tableName, columnName])
  @@index([workspaceId])
  @@map("column_analytics")
}

/// Bulk-ingested corpus documents (EMR, lab systems, financial, manual) used by
/// the Corpus Ingestion Engine and the Evolution Tracker maturation score.
model CorpusDocument {
  id        String             @id @default(cuid())
  title     String
  content   String
  source    String // emr, lab_system, financial, manual, bulk
  sourceId  String             @map("source_id")
  domain    IntelligenceDomain @default(OPERATIONAL)
  metadata  Json?
  workspaceId String           @map("workspace_id")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  @@index([workspaceId])
  @@index([domain])
  @@index([sourceId])
  @@map("corpus_documents")
}

