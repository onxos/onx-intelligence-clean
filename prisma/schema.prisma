generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String     @id @default(cuid())
  email       String     @unique
  password    String
  name        String
  status      UserStatus @default(ACTIVE)
  roleId      String     @map("role_id")
  workspaceId String     @map("workspace_id")
  tenantId    String     @map("tenant_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  sessions            Session[]
  devices             Device[]
  evidence            EvidenceRecord[]
  intelligenceObjects IntelligenceObject[]
  governanceDecisions GovernanceDecision[]
  projects            Project[]
  agents              Agent[]
  memoryItems         MemoryEntry[]

  role      Role      @relation(fields: [roleId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions Permission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id        String   @id @default(cuid())
  resource  String
  action    String
  createdAt DateTime @default(now()) @map("created_at")

  roles Role[]

  @@unique([resource, action])
  @@map("permissions")
}

model Workspace {
  id          String          @id @default(cuid())
  name        String
  description String?
  status      WorkspaceStatus @default(ACTIVE)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  users                      User[]
  intelligenceObjects        IntelligenceObject[]
  intelObjectRelationships   IntelligenceObjectRelationship[]
  intelObjectProvenance      IntelligenceObjectProvenance[]
  intelObjectLifecycleEvents IntelligenceObjectLifecycleEvent[]
  intelligenceSources        IntelligenceSource[]
  intelligenceFeeds          IntelligenceFeed[]
  feedPipelineEvents         FeedPipelineEvent[]
  learningStates             LearningState[]
  learningEvents             LearningEvent[]
  patterns                   Pattern[]
  knowledgeEvolutions        KnowledgeEvolution[]
  capitalizationEvents       CapitalizationEvent[]
  evidence                   EvidenceRecord[]
  providers                  ProviderProfile[]
  tools                      ToolProfile[]
  governanceDecisions        GovernanceDecision[]
  capitalRecords             CapitalRecord[]
  capitalAllocations         CapitalAllocation[]
  allocationPolicies         AllocationPolicy[]
  allocationDecisions        AllocationDecision[]
  allocationApprovals        AllocationApproval[]
  allocationHistories        AllocationHistory[]
  projects                   Project[]
  agents                     Agent[]
  memoryItems                MemoryEntry[]
  founderIntents             FounderIntent[]
  founderIntentVersions      FounderIntentVersion[]
  founderIntentRelationships FounderIntentRelationship[]
  founderIntentReviews       FounderIntentReview[]
  founderIntentConflicts     FounderIntentConflict[]
  founderOverrideEvents      FounderOverrideEvent[]
  intelligenceCapitals       IntelligenceCapital[]
  capitalAccumulationEvents  CapitalAccumulationEvent[]
  iucEntities                IUCEntity[]
  understandingEvents        UnderstandingEvent[]
  understandingEvidence      UnderstandingEvidence[]
  understandingRelationships UnderstandingRelationship[]
  measurementProfiles        MeasurementProfile[]
  measurementRecords         MeasurementRecord[]
  measurementHistory         MeasurementHistory[]
  measurementEvidence        MeasurementEvidence[]
  measurementBenchmarks      MeasurementBenchmark[]
  measurementFeedback        MeasurementFeedback[]
  runtimeSessions            RuntimeSession[]
  runtimeStates              RuntimeState[]
  runtimeContexts            RuntimeContext[]
  runtimeEvents              RuntimeEvent[]
  runtimeCheckpoints         RuntimeCheckpoint[]
  runtimeSnapshots           RuntimeSnapshot[]
  runtimeRecoveries          RuntimeRecovery[]
  runtimeHistory             RuntimeHistory[]
  runtimePolicies            RuntimePolicy[]
  exchangeSessions           ExchangeSession[]
  exchangeTransactions       ExchangeTransaction[]
  exchangeEnvelopes          ExchangeEnvelope[]
  exchangeMessages           ExchangeMessage[]
  exchangeReceipts           ExchangeReceipt[]
  exchangeAudits             ExchangeAudit[]
  exchangeHistory            ExchangeHistory[]
  exchangePolicies           ExchangePolicy[]
  exchangeLineages           ExchangeLineage[]
  exchangeContexts           ExchangeContext[]

  proofSessions       ProofSession[]
  proofScenarios      ProofScenario[]
  proofExecutions     ProofExecution[]
  proofResults        ProofResult[]
  proofEvidence       ProofEvidence[]
  proofFindings       ProofFinding[]
  proofCertifications ProofCertification[]
  proofHistory        ProofHistory[]
  stressCampaigns     StressCampaign[]
  stressScenarios     StressScenario[]
  stressExecutions    StressExecution[]
  failureInjections   FailureInjection[]
  stressResults       StressResult[]
  stressEvidence      StressEvidence[]
  recoveryEvidence    RecoveryEvidence[]
  stressHistory       StressHistory[]
  contradictions      Contradiction[]

  metaOrchestrationSessions MetaOrchestrationSession[]
  metaExecutionPlans        MetaExecutionPlan[]
  metaExecutionSteps        MetaExecutionStep[]
  metaExecutionContexts     MetaExecutionContext[]
  metaExecutionStates       MetaExecutionState[]
  metaExecutionHistory      MetaExecutionHistory[]
  metaExecutionEvidence     MetaExecutionEvidence[]
  metaRoutingDecisions      MetaRoutingDecision[]
  metaArbitrations          MetaArbitration[]
  metaMergeRequests         MetaMergeRequest[]
  metaMergeHistory          MetaMergeHistory[]
  metaOverrideEvents        MetaOverrideEvent[]
  metaRoutingPolicies       MetaRoutingPolicy[]
  metaArbitrationPolicies   MetaArbitrationPolicy[]
  metaMergePolicies         MetaMergePolicy[]
  metaExecutionPolicies     MetaExecutionPolicy[]

  usfipSessions   USFIPSession[]
  usfipProtocols  USFIPProtocol[]
  usfipRules      USFIPRule[]
  usfipPolicies   USFIPPolicy[]
  usfipExecutions USFIPExecution[]
  usfipHistory    USFIPHistory[]
  usfipEvidence   USFIPEvidence[]

  ifcProfiles   IFCProfile[]
  ifcDimensions IFCDimension[]
  ifcIndicators IFCIndicator[]
  ifcScores     IFCScore[]
  ifcSignals    IFCSignal[]
  ifcHistory    IFCHistory[]
  ifcEvidence   IFCEvidence[]
  ifcPolicies   IFCPolicy[]

  fiarAssets          FIARAsset[]
  fiarCategories      FIARCategory[]
  fiarClassifications FIARClassification[]
  fiarOwnerships      FIAROwnership[]
  fiarRelationships   FIARRelationship[]
  fiarHistory         FIARHistory[]
  fiarEvidence        FIAREvidence[]
  fiarPolicies        FIARPolicy[]

  reasoningSessions    ReasoningSession[]
  reasoningContexts    ReasoningContext[]
  reasoningChains      ReasoningChain[]
  reasoningSteps       ReasoningStep[]
  reasoningResults     ReasoningResult[]
  reasoningEvidence    ReasoningEvidence[]
  reasoningValidations ReasoningValidation[]
  reasoningHistory     ReasoningHistory[]

  planningSessions    PlanningSession[]
  planningContexts    PlanningContext[]
  planningGoals       PlanningGoal[]
  planningConstraints PlanningConstraint[]
  planningStrategies  PlanningStrategy[]
  planningPlans       PlanningPlan[]
  planningSteps       PlanningStep[]
  planningMilestones  PlanningMilestone[]
  planningEvidence    PlanningEvidence[]
  planningValidations PlanningValidation[]
  planningHistory     PlanningHistory[]

  decisionSessions    DecisionSession[]
  decisionContexts    DecisionContext[]
  decisionCandidates  DecisionCandidate[]
  decisionEvaluations DecisionEvaluation[]
  decisionConstraints DecisionConstraint[]
  decisionVerdicts    DecisionVerdict[]
  decisionEvidence    DecisionEvidence[]
  decisionValidations DecisionValidation[]
  decisionHistory     DecisionHistory[]

  implementationUnits        ImplementationUnit[]
  implementationPackages     ImplementationPackage[]
  implementationDependencies ImplementationDependency[]
  implementationBoundaries   ImplementationBoundary[]
  implementationEvidence     ImplementationEvidence[]
  implementationHistory      ImplementationHistory[]
  buildProfiles              BuildProfile[]
  deploymentProfiles         DeploymentProfile[]

  ficEnforcementChecks     FicEnforcementCheck[]
  ficConstraintEvaluations FicConstraintEvaluation[]
  ficEnforcementViolations FicEnforcementViolation[]

  iurgIntentObjects      IurgIntentObject[]
  iurgConstraintObjects  IurgConstraintObject[]
  iurgConflictObjects    IurgConflictObject[]
  iurgOverrideObjects    IurgOverrideObject[]
  iurgReviewObjects      IurgReviewObject[]
  iurgAmendmentObjects   IurgAmendmentObject[]
  iurgEnforcementObjects IurgEnforcementObject[]
  iurgViolationObjects   IurgViolationObject[]
  iurgEdges              IurgEdge[]
  intentEvolutionLedger  IntentEvolutionLedger[]

  sechRoutes SechRoute[]

  usfipPerceptionRecords UsfipPerceptionRecord[]

  decisionRuns DecisionRun[]

  sfisModelStatuses SfisModelStatus[]
  sfisScanRecords   SfisScanRecord[]

  detectedPatterns       DetectedPattern[]
  contextualizedPatterns ContextualizedPattern[]
  understandingObjects   UnderstandingObject[]

  judgmentObjects JudgmentObject[]

  continuityAudits ContinuityAudit[]

  selfAssessments    SelfAssessment[]
  crossModuleAudits  CrossModuleAudit[]
  overrideExecutions OverrideExecution[]
  systemHealthChecks SystemHealth[]

  aiQueryLogs AIQueryLog[]

  connectorConfigs ConnectorConfig[]
  connectorLogs    ConnectorLog[]

  @@map("workspaces")
}

model Tenant {
  id        String       @id @default(cuid())
  name      String
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  users User[]

  @@map("tenants")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("ACTIVE")
  workspaceId String   @map("workspace_id")
  ownerId     String   @map("owner_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  owner     User      @relation(fields: [ownerId], references: [id])

  @@index([workspaceId, createdAt])
  @@map("projects")
}

model Agent {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("ACTIVE")
  model       String?
  providerId  String?  @map("provider_id")
  config      Json?    @default("{}")
  workspaceId String   @map("workspace_id")
  ownerId     String   @map("owner_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  owner     User      @relation(fields: [ownerId], references: [id])

  @@index([workspaceId, createdAt])
  @@map("agents")
}

model MemoryEntry {
  id              String                @id @default(cuid())
  title           String
  content         String
  category        String                @default("GENERAL")
  classification  PrivacyLevel          @default(INSTITUTIONAL)
  accessScope     MemoryAccessScope     @default(WORKSPACE) @map("access_scope")
  lifecycleStatus MemoryLifecycleStatus @default(ACTIVE) @map("lifecycle_status")
  retentionDays   Int                   @default(1095) @map("retention_days")
  expiresAt       DateTime              @map("expires_at")
  tags            String[]              @default([])
  workspaceId     String                @map("workspace_id")
  ownerId         String                @map("owner_id")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  deletedAt       DateTime?             @map("deleted_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  owner     User      @relation(fields: [ownerId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([workspaceId, deletedAt, lifecycleStatus])
  @@index([workspaceId, ownerId, accessScope])
  @@map("memory_entries")
}

model Session {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String    @map("user_id")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  revokedAt DateTime? @map("revoked_at")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Device {
  id        String    @id @default(cuid())
  name      String
  userId    String    @map("user_id")
  lastSeen  DateTime? @map("last_seen")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("devices")
}

model IntelligenceObject {
  id              String                     @id @default(cuid())
  objectId        String                     @unique @default(cuid()) @map("object_id")
  name            String
  content         String
  contentHash     String                     @map("content_hash")
  semanticSummary String?                    @map("semantic_summary")
  objectType      IntelligenceObjectType     @map("object_type")
  layer           String                     @default("L1_FOUNDATIONAL")
  originSource    String                     @default("L2_SIL") @map("origin_source")
  creatorIdentity String                     @default("system") @map("creator_identity")
  ownershipClass  OwnershipClass             @default(INSTITUTIONAL) @map("ownership_class")
  amanahScore     Float                      @default(0.5) @map("amanah_score")
  confidenceScore Float                      @default(0.5) @map("confidence_score")
  trustScore      Float                      @default(0.5) @map("trust_score")
  qualityIndex    Float                      @default(0.5) @map("quality_index")
  state           ObjectState                @default(ACTIVE)
  shadowStatus    ShadowStatus               @default(INTERNAL) @map("shadow_status")
  sourceLayer     String                     @default("L1_FOUNDATIONAL") @map("source_layer")
  privacyLevel    PrivacyLevel               @default(INSTITUTIONAL) @map("privacy_level")
  ficValidated    Boolean                    @default(false) @map("fic_validated")
  constraintBasis String?                    @map("constraint_basis")
  capitalCategory CapitalCategory?           @map("capital_category")
  capitalValue    Float                      @default(0) @map("capital_value")
  lifecycleState  IntelligenceLifecycleState @default(DRAFT) @map("lifecycle_state")
  authorityLevel  AuthorityLevel             @default(OPERATIONAL) @map("authority_level")
  ownerId         String                     @map("owner_id")
  creatorId       String                     @map("creator_id")
  workspaceId     String                     @map("workspace_id")
  createdAt       DateTime                   @default(now()) @map("created_at")
  updatedAt       DateTime                   @updatedAt @map("updated_at")
  deletedAt       DateTime?                  @map("deleted_at")

  owner                User                               @relation(fields: [ownerId], references: [id])
  workspace            Workspace                          @relation(fields: [workspaceId], references: [id])
  evidence             EvidenceRecord[]
  provenance           ProvenanceRecord[]
  relationshipsFrom    IntelligenceObjectRelationship[]   @relation("RelationshipSource")
  relationshipsTo      IntelligenceObjectRelationship[]   @relation("RelationshipTarget")
  provenanceDimensions IntelligenceObjectProvenance[]
  lifecycleEvents      IntelligenceObjectLifecycleEvent[]

  @@index([workspaceId, deletedAt, lifecycleState])
  @@map("intelligence_objects")
}

model IntelligenceObjectRelationship {
  id               String                       @id @default(cuid())
  sourceObjectId   String                       @map("source_object_id")
  targetObjectId   String                       @map("target_object_id")
  relationshipType IntelligenceRelationshipType @map("relationship_type")
  workspaceId      String                       @map("workspace_id")
  createdById      String                       @map("created_by_id")
  metadata         Json?                        @default("{}")
  createdAt        DateTime                     @default(now()) @map("created_at")
  updatedAt        DateTime                     @updatedAt @map("updated_at")
  deletedAt        DateTime?                    @map("deleted_at")

  sourceObject IntelligenceObject @relation("RelationshipSource", fields: [sourceObjectId], references: [id])
  targetObject IntelligenceObject @relation("RelationshipTarget", fields: [targetObjectId], references: [id])
  workspace    Workspace          @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([sourceObjectId])
  @@index([targetObjectId])
  @@map("intelligence_object_relationships")
}

model IntelligenceObjectProvenance {
  id                 String                       @id @default(cuid())
  objectId           String                       @map("object_id")
  sourceIdentity     String                       @map("source_identity")
  origin             String
  creator            String
  extractionMethod   String                       @map("extraction_method")
  verificationStatus ProvenanceVerificationStatus @default(UNVERIFIED) @map("verification_status")
  confidence         Float                        @default(0.5)
  authorityLevel     AuthorityLevel               @default(OPERATIONAL) @map("authority_level")
  recordedAt         DateTime                     @default(now()) @map("recorded_at")
  workspaceId        String                       @map("workspace_id")
  createdById        String                       @map("created_by_id")
  createdAt          DateTime                     @default(now()) @map("created_at")
  updatedAt          DateTime                     @updatedAt @map("updated_at")

  object    IntelligenceObject @relation(fields: [objectId], references: [id])
  workspace Workspace          @relation(fields: [workspaceId], references: [id])

  @@index([objectId])
  @@index([workspaceId, createdAt])
  @@map("intelligence_object_provenance")
}

model IntelligenceObjectLifecycleEvent {
  id          String                      @id @default(cuid())
  objectId    String                      @map("object_id")
  fromState   IntelligenceLifecycleState? @map("from_state")
  toState     IntelligenceLifecycleState  @map("to_state")
  actorId     String                      @map("actor_id")
  workspaceId String                      @map("workspace_id")
  reason      String?
  metadata    Json?                       @default("{}")
  createdAt   DateTime                    @default(now()) @map("created_at")

  object    IntelligenceObject @relation(fields: [objectId], references: [id])
  workspace Workspace          @relation(fields: [workspaceId], references: [id])

  @@index([objectId, createdAt])
  @@index([workspaceId, createdAt])
  @@map("intelligence_object_lifecycle_events")
}

// ===========================================================================
// D11 — Intelligence Feeding Runtime
// ===========================================================================

model IntelligenceSource {
  id              String         @id @default(cuid())
  sourceId        String         @unique @default(cuid()) @map("source_id")
  identity        String
  description     String?
  category        SourceCategory @default(INTERNAL)
  authorityLevel  AuthorityLevel @default(OPERATIONAL) @map("authority_level")
  ownershipClass  OwnershipClass @default(INSTITUTIONAL) @map("ownership_class")
  trustScore      Float          @default(0.5) @map("trust_score")
  confidenceScore Float          @default(0.5) @map("confidence_score")
  status          SourceStatus   @default(ACTIVE)
  metadata        Json?          @default("{}")
  workspaceId     String         @map("workspace_id")
  createdById     String         @map("created_by_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  workspace Workspace          @relation(fields: [workspaceId], references: [id])
  feeds     IntelligenceFeed[]

  @@index([workspaceId, deletedAt, status])
  @@index([workspaceId, createdAt])
  @@map("intelligence_sources")
}

model IntelligenceFeed {
  id                String         @id @default(cuid())
  feedId            String         @unique @default(cuid()) @map("feed_id")
  sourceId          String         @map("source_id")
  payload           String
  contentHash       String         @map("content_hash")
  stage             FeedStage      @default(RECEIVED)
  shadowMode        FeedShadowMode @default(ACTIVE) @map("shadow_mode")
  classification    String?
  linkedObjectId    String?        @map("linked_object_id")
  trustScore        Float          @default(0.5) @map("trust_score")
  confidenceScore   Float          @default(0.5) @map("confidence_score")
  provenanceScore   Float          @default(0.5) @map("provenance_score")
  verificationScore Float          @default(0.5) @map("verification_score")
  validationResult  Json?          @map("validation_result")
  rejectionReason   String?        @map("rejection_reason")
  metadata          Json?          @default("{}")
  workspaceId       String         @map("workspace_id")
  createdById       String         @map("created_by_id")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  deletedAt         DateTime?      @map("deleted_at")

  source         IntelligenceSource  @relation(fields: [sourceId], references: [id])
  workspace      Workspace           @relation(fields: [workspaceId], references: [id])
  pipelineEvents FeedPipelineEvent[]

  @@index([workspaceId, deletedAt, stage])
  @@index([workspaceId, shadowMode])
  @@index([sourceId])
  @@map("intelligence_feeds")
}

model FeedPipelineEvent {
  id          String     @id @default(cuid())
  feedId      String     @map("feed_id")
  fromStage   FeedStage? @map("from_stage")
  toStage     FeedStage  @map("to_stage")
  actorId     String     @map("actor_id")
  workspaceId String     @map("workspace_id")
  notes       String?
  metadata    Json?      @default("{}")
  createdAt   DateTime   @default(now()) @map("created_at")

  feed      IntelligenceFeed @relation(fields: [feedId], references: [id])
  workspace Workspace        @relation(fields: [workspaceId], references: [id])

  @@index([feedId, createdAt])
  @@index([workspaceId, createdAt])
  @@map("feed_pipeline_events")
}

// ===========================================================================
// D12 — Intelligence Learning Runtime
// ===========================================================================

model LearningState {
  id                 String            @id @default(cuid())
  learningId         String            @unique @default(cuid()) @map("learning_id")
  title              String
  summary            String?
  objectId           String?           @map("object_id")
  state              LearningStateType @default(OBSERVED)
  confidence         Float             @default(0.5)
  reinforcementCount Int               @default(0) @map("reinforcement_count")
  contradictionCount Int               @default(0) @map("contradiction_count")
  capitalized        Boolean           @default(false)
  metadata           Json?             @default("{}")
  workspaceId        String            @map("workspace_id")
  createdById        String            @map("created_by_id")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  deletedAt          DateTime?         @map("deleted_at")

  workspace            Workspace             @relation(fields: [workspaceId], references: [id])
  events               LearningEvent[]
  knowledgeEvolutions  KnowledgeEvolution[]
  capitalizationEvents CapitalizationEvent[]

  @@index([workspaceId, deletedAt, state])
  @@index([workspaceId, createdAt])
  @@map("learning_states")
}

model LearningEvent {
  id          String             @id @default(cuid())
  learningId  String             @map("learning_id")
  eventType   LearningEventType  @map("event_type")
  fromState   LearningStateType? @map("from_state")
  toState     LearningStateType? @map("to_state")
  actorId     String             @map("actor_id")
  workspaceId String             @map("workspace_id")
  notes       String?
  metadata    Json?              @default("{}")
  createdAt   DateTime           @default(now()) @map("created_at")

  learning  LearningState @relation(fields: [learningId], references: [id])
  workspace Workspace     @relation(fields: [workspaceId], references: [id])

  @@index([learningId, createdAt])
  @@index([workspaceId, createdAt])
  @@map("learning_events")
}

model Pattern {
  id              String      @id @default(cuid())
  patternId       String      @unique @default(cuid()) @map("pattern_id")
  patternType     PatternType @map("pattern_type")
  label           String
  description     String?
  strength        Float       @default(0.5)
  occurrences     Int         @default(1)
  memberObjectIds String[]    @default([]) @map("member_object_ids")
  metadata        Json?       @default("{}")
  workspaceId     String      @map("workspace_id")
  createdById     String      @map("created_by_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, deletedAt, patternType])
  @@index([workspaceId, createdAt])
  @@map("patterns")
}

model KnowledgeEvolution {
  id            String        @id @default(cuid())
  learningId    String        @map("learning_id")
  evolutionType EvolutionType @map("evolution_type")
  reason        String?
  before        Json?
  after         Json?
  actorId       String        @map("actor_id")
  workspaceId   String        @map("workspace_id")
  createdById   String        @map("created_by_id")
  createdAt     DateTime      @default(now()) @map("created_at")

  learning  LearningState @relation(fields: [learningId], references: [id])
  workspace Workspace     @relation(fields: [workspaceId], references: [id])

  @@index([learningId, createdAt])
  @@index([workspaceId, createdAt])
  @@map("knowledge_evolutions")
}

model CapitalizationEvent {
  id              String               @id @default(cuid())
  learningId      String               @map("learning_id")
  objectId        String?              @map("object_id")
  triggerReason   String               @map("trigger_reason")
  capitalValue    Float                @default(0) @map("capital_value")
  capitalCategory CapitalCategory?     @map("capital_category")
  status          CapitalizationStatus @default(TRIGGERED)
  metadata        Json?                @default("{}")
  actorId         String               @map("actor_id")
  workspaceId     String               @map("workspace_id")
  createdById     String               @map("created_by_id")
  createdAt       DateTime             @default(now()) @map("created_at")

  learning  LearningState @relation(fields: [learningId], references: [id])
  workspace Workspace     @relation(fields: [workspaceId], references: [id])

  @@index([learningId, createdAt])
  @@index([workspaceId, createdAt])
  @@map("capitalization_events")
}

model ProviderProfile {
  id                      String         @id @default(cuid())
  providerId              String         @unique @map("provider_id")
  providerName            String         @map("provider_name")
  status                  ProviderStatus @default(ACTIVE)
  priority                Int            @default(1)
  domainFitness           Float          @default(0) @map("domain_fitness")
  riskFitness             Float          @default(0) @map("risk_fitness")
  historicalPerformance   Float          @default(0) @map("historical_performance")
  evidenceQuality         Float          @default(0) @map("evidence_quality")
