// USFIP Perception Bus (HC-12) and is evidence-tiered (AC-05). ConnectorConfig
// holds per-workspace connection settings; ConnectorLog is the immutable trail
// of every ingestion event, bound by value to its UsfipPerceptionRecord.
// ---------------------------------------------------------------------------
model ConnectorConfig {
  id          String    @id @default(cuid())
  workspaceId String    @map("workspace_id")
  connector   String
  provider    String
  isActive    Boolean   @default(false) @map("is_active")
  credentials Json?
  settings    Json?
  lastSyncAt  DateTime? @map("last_sync_at")
  lastError   String?   @map("last_error")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, connector, provider])
  @@index([workspaceId, isActive])
  @@map("connector_configs")
}

model ConnectorLog {
  id            String   @id @default(cuid())
  workspaceId   String   @map("workspace_id")
  connector     String
  provider      String
  eventType     String   @map("event_type")
  externalId    String?  @map("external_id")
  rawPayload    Json     @map("raw_payload")
  status        String   @default("pending")
  usfipRecordId String?  @map("usfip_record_id")
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, connector, createdAt])
  @@index([workspaceId, status])
  @@map("connector_logs")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("VIEWER")
  assignedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}
