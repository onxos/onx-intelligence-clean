  status         MetaPlanStatus @default(DRAFT)
  version        Int            @default(1)
  stepCount      Int            @default(0) @map("step_count")
  completedCount Int            @default(0) @map("completed_count")
  definition     Json?
  actorId        String         @map("actor_id")
  startedAt      DateTime?      @map("started_at")
  completedAt    DateTime?      @map("completed_at")
  metadata       Json?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")

  session   MetaOrchestrationSession @relation(fields: [sessionId], references: [id])
  workspace Workspace                @relation(fields: [workspaceId], references: [id])
  steps     MetaExecutionStep[]

  @@index([sessionId, createdAt])
  @@index([workspaceId, status])
  @@index([planId])
  @@map("meta_execution_plans")
}

model MetaExecutionStep {
  id            String          @id @default(cuid())
  stepId        String          @unique @default(cuid()) @map("step_id")
  planId        String          @map("plan_id")
  sessionId     String          @map("session_id")
  workspaceId   String          @map("workspace_id")
  sequence      Int             @default(0)
  name          String
  target        MetaRouteTarget
  status        MetaStepStatus  @default(PENDING)
  referenceId   String?         @map("reference_id")
