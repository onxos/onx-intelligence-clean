  signals               Json?
  status                SechRouteStatus @default(ROUTING)
  currentGate           String?         @map("current_gate")
  finalDecision         String?         @map("final_decision")
  gateResults           Json            @map("gate_results")
  conditions            String[]        @default([])
  counterProposal       String?         @map("counter_proposal")
  requiresHumanApproval Boolean         @default(false) @map("requires_human_approval")
  overrideExpiresAt     DateTime?       @map("override_expires_at")
  executed              Boolean         @default(false)
