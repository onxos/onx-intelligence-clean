// ===========================================================================
// Decision Engine (Wave 15) — determines the constitutionally valid decision.
// Consumes Reasoning, Planning, Measurement, Capital, Runtime, Objects, USFIP,
// IFC, FIAR and FIC by reference only. It NEVER executes actions.
// ===========================================================================

enum DecisionMode {
  OPERATIONAL
  STRATEGIC
  FOUNDER
  CONSTITUTIONAL
  EMERGENCY
  RECOVERY
  OPTIMIZATION
  CONSENSUS
}

enum DecisionSessionStatus {
  PENDING
  EVALUATING
  DECIDED
  FAILED
  OVERRIDDEN
}

enum DecisionCandidateStatus {
  PROPOSED
  FILTERED
  EVALUATED
  SELECTED
  REJECTED
}

enum DecisionVerdictKind {
  SELECTED
  CONTESTED
  DEFERRED
  BLOCKED
}

enum DecisionRiskLevel {
  LOW
  MODERATE
  ELEVATED
  CRITICAL
}

enum DecisionValidationKind {
  CONSTITUTIONAL
  FOUNDER
  EVIDENCE
  REASONING
  PLANNING
  CAPITAL
}

model DecisionSession {
  id                   String                @id @default(cuid())
  decisionSessionId    String                @unique @default(cuid()) @map("decision_session_id")
  workspaceId          String                @map("workspace_id")
  ownerId              String                @map("owner_id")
  mode                 DecisionMode
  objective            String
  focus                String?
  status               DecisionSessionStatus @default(PENDING)
  confidence           Float                 @default(0)
  verdict              DecisionVerdictKind?
  selectedCandidateId  String?               @map("selected_candidate_id")
  riskLevel            DecisionRiskLevel?    @map("risk_level")
  constraintsSatisfied Boolean               @default(true) @map("constraints_satisfied")
  candidateCount       Int                   @default(0) @map("candidate_count")
  constitutionalRef    String?               @map("constitutional_ref")
  overridden           Boolean               @default(false)
  version              Int                   @default(1)
  metadata             Json?
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  deletedAt            DateTime?             @map("deleted_at")

  workspace   Workspace            @relation(fields: [workspaceId], references: [id])
  contexts    DecisionContext[]
  candidates  DecisionCandidate[]
  evaluations DecisionEvaluation[]
  constraints DecisionConstraint[]
  verdicts    DecisionVerdict[]
  evidence    DecisionEvidence[]
  validations DecisionValidation[]
  history     DecisionHistory[]

  @@index([workspaceId, deletedAt, status])
  @@index([workspaceId, mode])
  @@index([workspaceId, createdAt])
  @@index([decisionSessionId])
  @@map("decision_sessions")
}

model DecisionContext {
  id            String   @id @default(cuid())
  contextId     String   @unique @default(cuid()) @map("context_id")
  sessionId     String   @map("session_id")
  workspaceId   String   @map("workspace_id")
  runtime       String
  referenceId   String?  @map("reference_id")
  referenceType String?  @map("reference_type")
  role          String
  weight        Float    @default(1)
  confidence    Float    @default(1)
  summary       String?
  payload       Json?
  actorId       String   @map("actor_id")
  createdAt     DateTime @default(now()) @map("created_at")

  session   DecisionSession @relation(fields: [sessionId], references: [id])
  workspace Workspace       @relation(fields: [workspaceId], references: [id])

  @@index([sessionId, createdAt])
  @@index([workspaceId, runtime])
  @@index([contextId])
  @@map("decision_contexts")
}

model DecisionCandidate {
  id                   String                  @id @default(cuid())
  candidateId          String                  @unique @default(cuid()) @map("candidate_id")
  sessionId            String                  @map("session_id")
  workspaceId          String                  @map("workspace_id")
  label                String
  description          String?
  status               DecisionCandidateStatus @default(PROPOSED)
  weight               Float                   @default(1)
  benefit              Float                   @default(0.5)
  cost                 Float                   @default(0)
  admissible           Boolean                 @default(true)
  reasoningConfidence  Float?                  @map("reasoning_confidence")
