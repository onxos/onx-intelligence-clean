  session   ReasoningSession @relation(fields: [sessionId], references: [id])
  workspace Workspace        @relation(fields: [workspaceId], references: [id])
  steps     ReasoningStep[]

  @@index([sessionId, sequence])
  @@index([workspaceId, status])
  @@index([chainId])
  @@map("reasoning_chains")
}

model ReasoningStep {
  id          String            @id @default(cuid())
  stepId      String            @unique @default(cuid()) @map("step_id")
  chainId     String            @map("chain_id")
