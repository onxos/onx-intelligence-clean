// ---------------------------------------------------------------------------
// IW-25 — SECH Integration (CCP v1.0 Section 11)
// The SECH decision router runs FIC checks automatically at 4 gates
// (pre_judgment, pre_decision, pre_execution, post_outcome). Each gate delegates
// to FicEnforcementService.runCheck (which persists a FicEnforcementCheck and
// binds the event into IURG). A SechRoute records the gate sequence + terminal
// disposition; CONFLICT routes await human resolution (/sech/pending).
// ---------------------------------------------------------------------------

enum SechRouteStatus {
  ROUTING
  APPROVED
  REJECTED
  CONFLICT
  OVERRIDE
  COMPLETED
  FAILED
}

model SechRoute {
  id                    String          @id @default(cuid())
