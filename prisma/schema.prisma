enum ImplementationUnitKind {
  RUNTIME
  ENGINE
  PROTOCOL
  GOVERNANCE
  REGISTRY
  INTERFACE
  INFRASTRUCTURE
}

enum ImplementationUnitStatus {
  DECLARED
  VALIDATED
  BUILT
  DEPLOYED
  DEPRECATED
  OVERRIDDEN
}

enum ImplementationBoundaryKind {
  EXECUTION
  RUNTIME
  BUILD
  DEPLOYMENT
  DEPENDENCY
}

enum ImplementationDependencyKind {
  REQUIRED
  OPTIONAL
  PEER
  BUILD
  RUNTIME
}

enum BuildProfileStatus {
  DRAFT
  VALIDATED
  FAILED
  PUBLISHED
}

enum DeploymentProfileStatus {
  DRAFT
  VALIDATED
