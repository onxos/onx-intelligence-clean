model FounderIntentConflict {
  id                    String                        @id @default(cuid())
  intentId              String                        @map("intent_id")
  counterpartIntentId   String?                       @map("counterpart_intent_id")
  conflictType          FounderIntentConflictType     @map("conflict_type")
