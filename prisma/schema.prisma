enum MetaSessionState {
  OPEN
  PLANNING
  EXECUTING
  MERGING
  COMPLETED
  OVERRIDDEN
  FAILED
  ARCHIVED
}

enum MetaPlanStatus {
  DRAFT
  READY
  RUNNING
  COMPLETED
  FAILED
}

enum MetaStepStatus {
  PENDING
  ROUTED
  RUNNING
  COMPLETED
  SKIPPED
  FAILED
}

enum MetaExecutionStatus {
  IDLE
  RUNNING
  BLOCKED
  COMPLETED
  FAILED
}

enum MetaRouteTarget {
  KNOWLEDGE
  LEARNING
  RUNTIME
  EXCHANGE
  MEASUREMENT
  CAPITAL
  INTENT
  WORKSPACE
  PROVIDER
}

enum MetaArbitrationType {
  CONFLICT
  PRIORITY
  AUTHORITY
  EVIDENCE
  CAPITAL
  EXECUTION
}

enum MetaArbitrationOutcome {
  RESOLVED
  ESCALATED
  DEADLOCK
}

enum MetaMergeStatus {
  REQUESTED
  VALIDATED
  MERGED
  REJECTED
  ROLLED_BACK
}

enum MetaOverrideType {
  MANUAL
  CONSTITUTIONAL
  PRIORITY
  EXECUTION
}

enum MetaPolicyStatus {
  ACTIVE
  INACTIVE
}

model MetaOrchestrationSession {
  id              String           @id @default(cuid())
  orchestrationId String           @unique @default(cuid()) @map("orchestration_id")
  name            String
  description     String?
  workspaceId     String           @map("workspace_id")
  ownerId         String           @map("owner_id")
  state           MetaSessionState @default(OPEN)
  objective       String?
  targetDomain    String?          @map("target_domain")
  planSeq         Int              @default(0) @map("plan_seq")
  eventSeq        Int              @default(0) @map("event_seq")
  overridden      Boolean          @default(false)
  status          String           @default("ACTIVE")
  metadata        Json?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")

  workspace        Workspace               @relation(fields: [workspaceId], references: [id])
  plans            MetaExecutionPlan[]
  steps            MetaExecutionStep[]
  contexts         MetaExecutionContext[]
  states           MetaExecutionState[]
  history          MetaExecutionHistory[]
  evidence         MetaExecutionEvidence[]
  routingDecisions MetaRoutingDecision[]
  arbitrations     MetaArbitration[]
  mergeRequests    MetaMergeRequest[]
  overrideEvents   MetaOverrideEvent[]

  @@index([workspaceId, deletedAt, state])
  @@index([workspaceId, createdAt])
  @@index([orchestrationId])
  @@map("meta_orchestration_sessions")
}

model MetaExecutionPlan {
  id             String         @id @default(cuid())
  planId         String         @unique @default(cuid()) @map("plan_id")
  sessionId      String         @map("session_id")
