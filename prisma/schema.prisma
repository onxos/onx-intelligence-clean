generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  status      UserStatus @default(ACTIVE)
  roleId      String   @map("role_id")
  workspaceId String   @map("workspace_id")
  tenantId    String   @map("tenant_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sessions    Session[]
  devices     Device[]
  evidence    EvidenceRecord[]
  intelligenceObjects IntelligenceObject[]
  governanceDecisions GovernanceDecision[]
  projects    Project[]
  agents      Agent[]
  memoryItems MemoryEntry[]

  role      Role      @relation(fields: [roleId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@map("users")
}

model Role {
  id          String @id @default(cuid())
  name        String @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions Permission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id        String   @id @default(cuid())
  resource  String
  action    String
  createdAt DateTime @default(now()) @map("created_at")

  roles Role[]

  @@unique([resource, action])
  @@map("permissions")
}

model Workspace {
  id          String @id @default(cuid())
  name        String
  description String?
  status      WorkspaceStatus @default(ACTIVE)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]
  intelligenceObjects IntelligenceObject[]
  intelObjectRelationships   IntelligenceObjectRelationship[]
  intelObjectProvenance      IntelligenceObjectProvenance[]
  intelObjectLifecycleEvents IntelligenceObjectLifecycleEvent[]
  evidence    EvidenceRecord[]
  providers   ProviderProfile[]
  tools       ToolProfile[]
  governanceDecisions GovernanceDecision[]
  capitalRecords CapitalRecord[]
  capitalAllocations CapitalAllocation[]
  allocationPolicies AllocationPolicy[]
  allocationDecisions AllocationDecision[]
  allocationApprovals AllocationApproval[]
  allocationHistories AllocationHistory[]
  projects Project[]
  agents   Agent[]
  memoryItems MemoryEntry[]

  @@map("workspaces")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("tenants")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("ACTIVE")
  workspaceId String   @map("workspace_id")
  ownerId     String   @map("owner_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  owner     User      @relation(fields: [ownerId], references: [id])

  @@index([workspaceId, createdAt])
  @@map("projects")
}

model Agent {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("ACTIVE")
  model       String?
  providerId  String?  @map("provider_id")
  config      Json?    @default("{}")
  workspaceId String   @map("workspace_id")
  ownerId     String   @map("owner_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  owner     User      @relation(fields: [ownerId], references: [id])

  @@index([workspaceId, createdAt])
  @@map("agents")
}

model MemoryEntry {
  id              String                @id @default(cuid())
  title           String
  content         String
  category        String                @default("GENERAL")
  classification  PrivacyLevel          @default(INSTITUTIONAL)
  accessScope     MemoryAccessScope     @default(WORKSPACE) @map("access_scope")
  lifecycleStatus MemoryLifecycleStatus @default(ACTIVE) @map("lifecycle_status")
  retentionDays   Int                   @default(1095) @map("retention_days")
  expiresAt       DateTime              @map("expires_at")
  tags            String[]              @default([])
  workspaceId     String                @map("workspace_id")
  ownerId         String                @map("owner_id")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  deletedAt       DateTime?             @map("deleted_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  owner     User      @relation(fields: [ownerId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([workspaceId, deletedAt, lifecycleStatus])
  @@index([workspaceId, ownerId, accessScope])
  @@map("memory_entries")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  revokedAt DateTime? @map("revoked_at")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Device {
  id       String @id @default(cuid())
  name     String
  userId   String @map("user_id")
  lastSeen DateTime? @map("last_seen")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("devices")
}

model IntelligenceObject {
  id              String            @id @default(cuid())
  objectId        String            @unique @default(cuid()) @map("object_id")
  name            String
  content         String
  contentHash     String            @map("content_hash")
  semanticSummary String?           @map("semantic_summary")
  objectType      IntelligenceObjectType @map("object_type")
  layer           String            @default("L1_FOUNDATIONAL")
  originSource    String            @default("L2_SIL") @map("origin_source")
  creatorIdentity String            @default("system") @map("creator_identity")
  ownershipClass  OwnershipClass    @default(INSTITUTIONAL) @map("ownership_class")
  amanahScore     Float             @default(0.5) @map("amanah_score")
  confidenceScore Float             @default(0.5) @map("confidence_score")
  trustScore      Float             @default(0.5) @map("trust_score")
  qualityIndex    Float             @default(0.5) @map("quality_index")
  state           ObjectState       @default(ACTIVE)
  shadowStatus    ShadowStatus      @default(INTERNAL) @map("shadow_status")
  sourceLayer     String            @default("L1_FOUNDATIONAL") @map("source_layer")
  privacyLevel    PrivacyLevel      @default(INSTITUTIONAL) @map("privacy_level")
  ficValidated    Boolean           @default(false) @map("fic_validated")
  constraintBasis String?           @map("constraint_basis")
  capitalCategory CapitalCategory?  @map("capital_category")
  capitalValue    Float             @default(0) @map("capital_value")
  lifecycleState  IntelligenceLifecycleState @default(DRAFT) @map("lifecycle_state")
  authorityLevel  AuthorityLevel    @default(OPERATIONAL) @map("authority_level")
  ownerId         String            @map("owner_id")
  creatorId       String            @map("creator_id")
  workspaceId     String            @map("workspace_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")

  owner         User   @relation(fields: [ownerId], references: [id])
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  evidence      EvidenceRecord[]
  provenance    ProvenanceRecord[]
  relationshipsFrom    IntelligenceObjectRelationship[] @relation("RelationshipSource")
  relationshipsTo      IntelligenceObjectRelationship[] @relation("RelationshipTarget")
  provenanceDimensions IntelligenceObjectProvenance[]
  lifecycleEvents      IntelligenceObjectLifecycleEvent[]

  @@index([workspaceId, deletedAt, lifecycleState])
  @@map("intelligence_objects")
}

model IntelligenceObjectRelationship {
  id               String   @id @default(cuid())
  sourceObjectId   String   @map("source_object_id")
  targetObjectId   String   @map("target_object_id")
  relationshipType IntelligenceRelationshipType @map("relationship_type")
  workspaceId      String   @map("workspace_id")
  createdById      String   @map("created_by_id")
  metadata         Json?    @default("{}")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  sourceObject IntelligenceObject @relation("RelationshipSource", fields: [sourceObjectId], references: [id])
  targetObject IntelligenceObject @relation("RelationshipTarget", fields: [targetObjectId], references: [id])
  workspace    Workspace          @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([sourceObjectId])
  @@index([targetObjectId])
  @@map("intelligence_object_relationships")
}

model IntelligenceObjectProvenance {
  id                 String   @id @default(cuid())
  objectId           String   @map("object_id")
  sourceIdentity     String   @map("source_identity")
  origin             String
  creator            String
  extractionMethod   String   @map("extraction_method")
  verificationStatus ProvenanceVerificationStatus @default(UNVERIFIED) @map("verification_status")
  confidence         Float    @default(0.5)
  authorityLevel     AuthorityLevel @default(OPERATIONAL) @map("authority_level")
  recordedAt         DateTime @default(now()) @map("recorded_at")
  workspaceId        String   @map("workspace_id")
  createdById        String   @map("created_by_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  object    IntelligenceObject @relation(fields: [objectId], references: [id])
  workspace Workspace          @relation(fields: [workspaceId], references: [id])

  @@index([objectId])
  @@index([workspaceId, createdAt])
  @@map("intelligence_object_provenance")
}

model IntelligenceObjectLifecycleEvent {
  id          String   @id @default(cuid())
  objectId    String   @map("object_id")
  fromState   IntelligenceLifecycleState? @map("from_state")
  toState     IntelligenceLifecycleState  @map("to_state")
  actorId     String   @map("actor_id")
  workspaceId String   @map("workspace_id")
  reason      String?
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  object    IntelligenceObject @relation(fields: [objectId], references: [id])
  workspace Workspace          @relation(fields: [workspaceId], references: [id])

  @@index([objectId, createdAt])
  @@index([workspaceId, createdAt])
  @@map("intelligence_object_lifecycle_events")
}

model ProviderProfile {
  id             String @id @default(cuid())
  providerId     String @unique @map("provider_id")
  providerName   String @map("provider_name")
  status         ProviderStatus @default(ACTIVE)
  priority       Int    @default(1)
  domainFitness       Float @default(0) @map("domain_fitness")
  riskFitness         Float @default(0) @map("risk_fitness")
  historicalPerformance Float @default(0) @map("historical_performance")
  evidenceQuality     Float @default(0) @map("evidence_quality")
  judgmentQuality     Float @default(0) @map("judgment_quality")
  hallucinationResistance Float @default(0) @map("hallucination_resistance")
  governanceCompliance Float @default(0) @map("governance_compliance")
  costEfficiency      Float @default(0) @map("cost_efficiency")
  latency             Float @default(0)
  reliability         Float @default(0)
  outcomeSuccess      Float @default(0) @map("outcome_success")
  ownershipCompatibility Float @default(0) @map("ownership_compatibility")
  iseScore            Float @default(0) @map("ise_score")
  totalCapital        Float @default(0) @map("total_capital")
  models              String[]
  costPer1kTokens     Float @default(0) @map("cost_per_1k_tokens")
  latencyMs           Int    @default(0) @map("latency_ms")
  successRate         Float  @default(0) @map("success_rate")
  workspaceId         String @map("workspace_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  evaluations ProviderEvaluation[]

  @@map("provider_profiles")
}

model ProviderEvaluation {
  id        String   @id @default(cuid())
  providerId String  @map("provider_id")
  iseScore  Float   @map("ise_score")
  dimensions Json   @default("{}")
  intent    String
  context   String?
  createdAt DateTime @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  provider ProviderProfile @relation(fields: [providerId], references: [id])

  @@map("provider_evaluations")
}

model ToolProfile {
  id        String @id @default(cuid())
  toolId    String @unique @map("tool_id")
  toolName  String @map("tool_name")
  category  ToolCategory
  status    ToolStatus @default(ACTIVE)
  capabilities String[]
  costPerCall Float @default(0) @map("cost_per_call")
  totalCapital Float @default(0) @map("total_capital")
  workspaceId String @map("workspace_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@map("tool_profiles")
}

model EvidenceRecord {
  id        String   @id @default(cuid())
  evidenceId String  @unique @default(cuid()) @map("evidence_id")
  intent    String
  intelligenceObjectId String? @map("intelligence_object_id")
  ownerId   String   @map("owner_id")
  workspaceId String @map("workspace_id")
  confidence Float  @default(0)
  cost      Float   @default(0)
  latencyMs Int     @default(0) @map("latency_ms")
  evidenceQuality Float @default(0) @map("evidence_quality")
  capitalCreated Float @default(0) @map("capital_created")
  providerCandidates String[] @default([]) @map("provider_candidates")
  providerSelected String? @map("provider_selected")
  toolCandidates String[] @default([]) @map("tool_candidates")
  toolSelected String? @map("tool_selected")
  judgment  String?
  outcome   String?
  learning  String?
  createdAt DateTime @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  owner     User @relation(fields: [ownerId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  intelligenceObject IntelligenceObject? @relation(fields: [intelligenceObjectId], references: [id])

  @@map("evidence_records")
}

model GovernanceDecision {
  id           String @id @default(cuid())
  decisionType String @map("decision_type")
  outcome      String @default("UNDEFINED")
  amanahScore  Float @map("amanah_score")
  confidence   Float @default(0.5)
  ficValidated Boolean @default(false) @map("fic_validated")
  actorId      String @map("actor_id")
  workspaceId  String @map("workspace_id")
  createdAt    DateTime @default(now()) @map("created_at")

  actor     User @relation(fields: [actorId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@map("governance_decisions")
}

model CapitalRecord {
  id        String @id @default(cuid())
  type      String
  amount    Float
  category  CapitalCategory
  workspaceId String @map("workspace_id")
  ownerId   String @map("owner_id")
  sourceObjectId String? @map("source_object_id")
  createdAt DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@map("capital_records")
}

model CapitalAllocation {
  id             String                   @id @default(cuid())
  workspaceId    String                   @map("workspace_id")
  ownerId        String                   @map("owner_id")
  policyId       String?                  @map("policy_id")
  category       CapitalCategory
  amount         Float
  currency       String                   @default("USD")
  source         String?
  target         String?
  status         AllocationStatus         @default(DRAFT)
  priority       Int                      @default(3)
  rationale      String?
  decisionReason String?                  @map("decision_reason")
  approvalStatus AllocationApprovalStatus @default(PENDING) @map("approval_status")
  approvedBy     String?                  @map("approved_by")
  approvedAt     DateTime?                @map("approved_at")
  rejectedAt     DateTime?                @map("rejected_at")
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")
  deletedAt      DateTime?                @map("deleted_at")

  workspace Workspace         @relation(fields: [workspaceId], references: [id])
  policy    AllocationPolicy? @relation(fields: [policyId], references: [id])
  decisions AllocationDecision[]
  approvals AllocationApproval[]
  history   AllocationHistory[]

  @@index([workspaceId, deletedAt, status])
  @@index([workspaceId, category, createdAt])
  @@map("capital_allocations")
}

model AllocationPolicy {
  id         String       @id @default(cuid())
  workspaceId String      @map("workspace_id")
  ownerId    String       @map("owner_id")
  name       String
  description String?
  category   CapitalCategory
  currency   String       @default("USD")
  source     String?
  target     String?
  status     PolicyStatus @default(ACTIVE)
  priority   Int          @default(3)
  rationale  String?
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  deletedAt  DateTime?    @map("deleted_at")

  workspace   Workspace           @relation(fields: [workspaceId], references: [id])
  allocations CapitalAllocation[]
  history     AllocationHistory[]

  @@index([workspaceId, deletedAt, status])
  @@index([workspaceId, category, createdAt])
  @@map("allocation_policies")
}

model AllocationDecision {
  id             String           @id @default(cuid())
  allocationId   String           @map("allocation_id")
  workspaceId    String           @map("workspace_id")
  actorId        String           @map("actor_id")
  status         AllocationStatus
  priority       Int              @default(3)
  rationale      String?
  decisionReason String?          @map("decision_reason")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")

  allocation CapitalAllocation @relation(fields: [allocationId], references: [id])
  workspace  Workspace         @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, allocationId, createdAt])
  @@map("allocation_decisions")
}

model AllocationApproval {
  id             String                   @id @default(cuid())
  allocationId   String                   @map("allocation_id")
  workspaceId    String                   @map("workspace_id")
  actorId        String                   @map("actor_id")
  approvalStatus AllocationApprovalStatus @map("approval_status")
  approvedBy     String?                  @map("approved_by")
  approvedAt     DateTime?                @map("approved_at")
  rejectedAt     DateTime?                @map("rejected_at")
  decisionReason String?                  @map("decision_reason")
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")
  deletedAt      DateTime?                @map("deleted_at")

  allocation CapitalAllocation @relation(fields: [allocationId], references: [id])
  workspace  Workspace         @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, allocationId, createdAt])
  @@map("allocation_approvals")
}

model AllocationHistory {
  id             String    @id @default(cuid())
  allocationId   String?   @map("allocation_id")
  policyId       String?   @map("policy_id")
  workspaceId    String    @map("workspace_id")
  actorId        String    @map("actor_id")
  action         String
  status         String?
  rationale      String?
  decisionReason String?   @map("decision_reason")
  previousState  Json?     @map("previous_state")
  nextState      Json?     @map("next_state")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  allocation CapitalAllocation? @relation(fields: [allocationId], references: [id])
  policy     AllocationPolicy?  @relation(fields: [policyId], references: [id])
  workspace  Workspace          @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([allocationId, createdAt])
  @@index([policyId, createdAt])
  @@map("allocation_histories")
}

model ProvenanceRecord {
  id        String @id @default(cuid())
  action    String
  resource  String
  resourceId String? @map("resource_id")
  actorId   String @map("actor_id")
  workspaceId String? @map("workspace_id")
  oldValue  String? @map("old_value")
  newValue  String? @map("new_value")
  createdAt DateTime @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  intelligenceObject IntelligenceObject? @relation(fields: [resourceId], references: [id])

  @@map("provenance_records")
}

model FrontierAsset {
  id          String @id @default(cuid())
  assetId     String @unique @map("asset_id")
  name        String
  assetClass  String @map("asset_class")
  status      AssetStatus @default(CATALOGED)
  priorityScore Float @default(0) @map("priority_score")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("frontier_assets")
}

model SovereigntyMetric {
  id          String @id @default(cuid())
  metricType  String @map("metric_type")
  value       Float
  ksr         Float?
  pdr         Float?
  krr         Float?
  kor         Float?
  scg         Float?
  sai         Float?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("sovereignty_metrics")
}

model AuditLog {
  id           String   @id @default(cuid())
  eventId      String   @unique @map("event_id")
  timestamp    DateTime @default(now())
  action       String
  resource     String
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id")
  actorId      String   @map("actor_id")
  workspaceId  String?  @map("workspace_id")
  oldValue     String?  @map("old_value")
  newValue     String?  @map("new_value")
  before       Json?
  after        Json?
  requestId    String?  @map("request_id")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  status       String   @default("SUCCESS")
  success      Boolean  @default(true)
  metadata     Json?    @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum WorkspaceStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum TenantStatus {
  ACTIVE
  INACTIVE
}

enum IntelligenceObjectType {
  SIGNAL
  PATTERN
  JUDGMENT
  UNDERSTANDING
  WISDOM
  EXTERNAL_INTELLIGENCE
  INTENT
  KNOWLEDGE
  EVIDENCE
  SOURCE
  MODEL
  TOOL
  AGENT
  EVALUATION
  MEMORY
  DECISION
  MEASUREMENT
  CAPITAL
}

enum ObjectState {
  ACTIVE
  DORMANT
  DEPRECATED
  ARCHIVED
}

enum IntelligenceLifecycleState {
  DRAFT
  INGESTED
  VALIDATED
  ACTIVE
  LINKED
  MEASURED
  CAPITALIZED
  DEPRECATED
  ARCHIVED
}

enum IntelligenceRelationshipType {
  DERIVES_FROM
  SUPPORTS
  CONTRADICTS
  REFINES
  REPLACES
  DEPENDS_ON
  MEASURES
  GOVERNS
  CAPITALIZES
  BELONGS_TO
}

enum ProvenanceVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum AuthorityLevel {
  SYSTEM
  OPERATIONAL
  INSTITUTIONAL
  SOVEREIGN
}

enum ShadowStatus {
  INTERNAL
  EXTERNAL
  HYBRID
}

enum OwnershipClass {
  PERSONAL
  COMPANION
  INSTITUTIONAL
  CIVILIZATION
}

enum PrivacyLevel {
  PUBLIC
  INSTITUTIONAL
  CONFIDENTIAL
  RESTRICTED
}

enum CapitalCategory {
  CLINICAL
  OPERATIONS
  COMMERCIAL
  STRATEGY
  GOVERNANCE
  KNOWLEDGE
}

enum AllocationStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ALLOCATED
  CANCELLED
  ARCHIVED
}

enum AllocationApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PolicyStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ProviderStatus {
  ACTIVE
  INACTIVE
  EXPERIMENTAL
  DEPRECATED
}

enum ToolCategory {
  SEARCH
  ANALYTICS
  AUTOMATION
  COMMUNICATION
  KNOWLEDGE
  MEDIA
}

enum ToolStatus {
  ACTIVE
  INACTIVE
  EXPERIMENTAL
}

