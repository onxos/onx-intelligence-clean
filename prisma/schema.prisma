// ---------------------------------------------------------------------------
// IW-23 — FIC Full Runtime Enforcement (SECH-FIC)
// Persisted runtime enforcement events. The constitutional constraint registry
// itself (68 constraints, 38 intents, 7 conflict classes, 10 playbook mappings,
// 13-step sequence) is code-versioned in src/intent-compiler/fic-enforcement.constants.ts.
// These tables record the IURG-bound Enforcement + Violation objects.
// ---------------------------------------------------------------------------

enum FicCheckDecision {
  APPROVED
  REJECTED
  CONFLICT
  OVERRIDE
}

enum FicConstraintKind {
  HC
  SC
  AC
  DG
  EB
  OVR
  OR
}

enum FicEvaluationOutcome {
  PASS
  VIOLATED
  FLAGGED
  GATE_REQUIRED
  BLOCKED
  ADVISORY
  NOT_APPLICABLE
}

enum FicViolationKind {
  EXECUTION_BLOCK
  HARD_CONSTRAINT
  CONFLICT
  OVERRIDE
}

model FicEnforcementCheck {
  id                      String           @id @default(cuid())
  checkId                 String           @unique @default(cuid()) @map("check_id")
  workspaceId             String           @map("workspace_id")
  requesterId             String           @map("requester_id")
  checkType               String?          @map("check_type")
  decisionContext         String?          @map("decision_context")
  playbooks               String[]         @default([])
  domains                 String[]         @default([])
  signals                 Json?
  decision                FicCheckDecision
  reason                  String
  applicableIntentIds     String[]         @default([]) @map("applicable_intent_ids")
  applicableConstraintIds String[]         @default([]) @map("applicable_constraint_ids")
  executionBlocks         String[]         @default([]) @map("execution_blocks")
  hardViolations          String[]         @default([]) @map("hard_violations")
  softFlags               String[]         @default([]) @map("soft_flags")
  requiredGates           String[]         @default([]) @map("required_gates")
  activeOverrides         String[]         @default([]) @map("active_overrides")
  priorityLevel           Int?             @map("priority_level")
  requiresHumanApproval   Boolean          @default(false) @map("requires_human_approval")
  counterProposal         String?          @map("counter_proposal")
  steps                   Json
  conflicts               Json?
  traceId                 String?          @map("trace_id")
  metadata                Json?
  createdAt               DateTime         @default(now()) @map("created_at")

  workspace   Workspace                 @relation(fields: [workspaceId], references: [id])
  evaluations FicConstraintEvaluation[]
  violations  FicEnforcementViolation[]

  @@index([workspaceId, createdAt])
  @@index([workspaceId, decision])
  @@index([checkId])
  @@map("fic_enforcement_checks")
}

model FicConstraintEvaluation {
  id           String               @id @default(cuid())
  checkId      String               @map("check_id")
  constraintId String               @map("constraint_id")
  kind         FicConstraintKind
  title        String
  outcome      FicEvaluationOutcome
  triggered    Boolean              @default(false)
  reason       String
  workspaceId  String               @map("workspace_id")
  createdAt    DateTime             @default(now()) @map("created_at")

  check     FicEnforcementCheck @relation(fields: [checkId], references: [id], onDelete: Cascade)
  workspace Workspace           @relation(fields: [workspaceId], references: [id])

  @@index([checkId])
  @@index([workspaceId, constraintId])
  @@map("fic_constraint_evaluations")
}

model FicEnforcementViolation {
  id           String           @id @default(cuid())
  violationId  String           @unique @default(cuid()) @map("violation_id")
  checkId      String           @map("check_id")
  constraintId String           @map("constraint_id")
  kind         FicViolationKind
  description  String
  autoUnblock  String?          @map("auto_unblock")
  workspaceId  String           @map("workspace_id")
  createdAt    DateTime         @default(now()) @map("created_at")

  check     FicEnforcementCheck @relation(fields: [checkId], references: [id], onDelete: Cascade)
  workspace Workspace           @relation(fields: [workspaceId], references: [id])

  @@index([checkId])
  @@index([workspaceId, kind])
  @@index([violationId])
  @@map("fic_enforcement_violations")
}

// ---------------------------------------------------------------------------
// IW-24 — IURG Full Binding (CCP v1.0 Section 12)
