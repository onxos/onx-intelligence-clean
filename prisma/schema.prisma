  description           String
  recommendedResolution String                        @map("recommended_resolution")
  metadata              Json?                         @default("{}")
  workspaceId           String                        @map("workspace_id")
  detectedById          String                        @map("detected_by_id")
  resolvedById          String?                       @map("resolved_by_id")
  resolvedAt            DateTime?                     @map("resolved_at")
  createdAt             DateTime                      @default(now()) @map("created_at")
  updatedAt             DateTime                      @updatedAt @map("updated_at")

  intent            FounderIntent  @relation("FounderIntentConflictPrimary", fields: [intentId], references: [id])
  counterpartIntent FounderIntent? @relation("FounderIntentConflictCounterpart", fields: [counterpartIntentId], references: [id])
  workspace         Workspace      @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, status, severity])
  @@index([intentId, createdAt])
  @@map("founder_intent_conflicts")
}

model FounderOverrideEvent {
