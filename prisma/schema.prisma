enum IFCProfileStatus {
  DRAFT
  ACTIVE
  DEGRADED
  OVERRIDDEN
  ARCHIVED
}

enum IFCDimensionKind {
  KNOWLEDGE
  EXECUTION
  GOVERNANCE
  LEARNING
  CAPITAL
  TRUST
  CONTINUITY
  FOUNDER_ALIGNMENT
}

enum IFCComponentStatus {
  ACTIVE
  INACTIVE
  DEGRADED
}

enum IFCTrend {
  RISING
  STABLE
  FALLING
}

enum IFCRiskLevel {
  LOW
  MODERATE
  ELEVATED
  CRITICAL
}

enum IFCSignalKind {
  CONTRIBUTION
  PRESERVATION
  GROWTH
  DECAY
  ALLOCATION
