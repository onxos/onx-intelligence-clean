// ===========================================================================
// Planning Engine (Wave 14)
// Additive: consumes Reasoning/Knowledge/Measurement/Exchange/Runtime/Objects/
// Capital/USFIP/IFC/FIAR/FIC by reference (no FK, no duplicated storage).
// Planning prepares executable strategic plans only — it NEVER decides.
// ===========================================================================

enum PlanningMode {
  OPERATIONAL
  STRATEGIC
  FOUNDER
  ADAPTIVE
  CONSTITUTIONAL
  SCENARIO
  RECOVERY
  OPTIMIZATION
}

enum PlanningSessionStatus {
  PENDING
  PLANNING
  COMPLETED
  FAILED
  OVERRIDDEN
}

enum PlanningPlanStatus {
  PRIMARY
  ALTERNATIVE
  SELECTED
  REJECTED
}

enum PlanningReadiness {
  EXECUTABLE
  CONDITIONAL
  BLOCKED
}

enum PlanningRiskLevel {
  LOW
  MODERATE
  ELEVATED
  CRITICAL
}

enum PlanningValidationKind {
  CONSTITUTIONAL
  RESOURCE
  DEPENDENCY
  GOAL
  RISK
  CONSISTENCY
}

model PlanningSession {
  id                   String                @id @default(cuid())
  planningSessionId    String                @unique @default(cuid()) @map("planning_session_id")
  workspaceId          String                @map("workspace_id")
