  deletedAt          DateTime?                @map("deleted_at")

  workspace       Workspace                  @relation(fields: [workspaceId], references: [id])
  package         ImplementationPackage?     @relation(fields: [packageId], references: [id])
  boundaries      ImplementationBoundary[]
  dependenciesOut ImplementationDependency[] @relation("ImplementationDependencyFrom")
  dependenciesIn  ImplementationDependency[] @relation("ImplementationDependencyTo")

  @@unique([workspaceId, slug])
  @@index([workspaceId, deletedAt, status])
  @@index([workspaceId, kind])
  @@index([workspaceId, createdAt])
  @@index([packageId])
  @@index([unitId])
