  slug               String
  kind               ImplementationUnitKind
  status             ImplementationUnitStatus @default(DECLARED)
  executionScope     String                   @map("execution_scope")
  ownership          String
  runtimeBoundary    String?                  @map("runtime_boundary")
  buildBoundary      String?                  @map("build_boundary")
  deploymentBoundary String?                  @map("deployment_boundary")
  packageId          String?                  @map("package_id")
  version            Int                      @default(1)
  dependencyCount    Int                      @default(0) @map("dependency_count")
  boundaryCount      Int                      @default(0) @map("boundary_count")
