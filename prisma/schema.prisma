  name              String
  description       String?
  status            FIARComponentStatus @default(ACTIVE)
  requireOwnership  Boolean             @default(true) @map("require_ownership")
  requireReference  Boolean             @default(false) @map("require_reference")
  allowedClasses    Json?               @map("allowed_classes")
  constitutionalRef String?             @map("constitutional_ref")
  rules             Json?
  actorId           String              @map("actor_id")
  metadata          Json?
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  deletedAt         DateTime?           @map("deleted_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, status])
  @@index([policyId])
  @@map("fiar_policies")
}

// ===========================================================================
// Reasoning Engine (Wave 13)
// Consumes Objects/Knowledge/Learning/Measurement/Exchange/Meta/USFIP/IFC/FIAR/
// FIC by reference (no FK, no duplicated storage). Additive only.
// NOT planning, NOT decision.
// ===========================================================================

enum ReasoningMode {
  DEDUCTIVE
  INDUCTIVE
  ABDUCTIVE
  ANALOGICAL
  CONSTRAINT
  STRATEGIC
  CONSTITUTIONAL
  FOUNDER_GUIDED
}

enum ReasoningSessionStatus {
  PENDING
  REASONING
  COMPLETED
  FAILED
  OVERRIDDEN
}

enum ReasoningChainStatus {
  PRIMARY
  ALTERNATIVE
  SELECTED
  REJECTED
}

enum ReasoningStepKind {
  CONTEXT_LOADING
  CHAIN_CONSTRUCTION
  EVIDENCE_AGGREGATION
  CONSTRAINT_EVALUATION
  CONFIDENCE_SCORING
  ALTERNATIVE_PATHS
  REASONING_TRACE
}

enum ReasoningVerdict {
  CONCLUSIVE
  PLAUSIBLE
  INCONCLUSIVE
  CONTESTED
}

enum ReasoningValidationKind {
  CONSTITUTIONAL
  TRUST
  EVIDENCE
  KNOWLEDGE
  CONSISTENCY
}

model ReasoningSession {
  id                   String                 @id @default(cuid())
  reasoningSessionId   String                 @unique @default(cuid()) @map("reasoning_session_id")
  workspaceId          String                 @map("workspace_id")
  ownerId              String                 @map("owner_id")
  mode                 ReasoningMode
  question             String
  objective            String?
  status               ReasoningSessionStatus @default(PENDING)
  confidence           Float                  @default(0)
  verdict              ReasoningVerdict?
  constraintsSatisfied Boolean                @default(true) @map("constraints_satisfied")
  alternativesCount    Int                    @default(0) @map("alternatives_count")
  constitutionalRef    String?                @map("constitutional_ref")
  overridden           Boolean                @default(false)
  version              Int                    @default(1)
  metadata             Json?
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  deletedAt            DateTime?              @map("deleted_at")

  workspace   Workspace             @relation(fields: [workspaceId], references: [id])
  contexts    ReasoningContext[]
  chains      ReasoningChain[]
  steps       ReasoningStep[]
  results     ReasoningResult[]
  evidence    ReasoningEvidence[]
  validations ReasoningValidation[]
  history     ReasoningHistory[]

  @@index([workspaceId, deletedAt, status])
  @@index([workspaceId, mode])
  @@index([workspaceId, createdAt])
  @@index([reasoningSessionId])
  @@map("reasoning_sessions")
}

model ReasoningContext {
  id            String   @id @default(cuid())
  contextId     String   @unique @default(cuid()) @map("context_id")
  sessionId     String   @map("session_id")
  workspaceId   String   @map("workspace_id")
