// ============================================================
// USFIP — Universal Strategic Founder Intelligence Protocol
// (Wave 10). Constitutional protocol governing how Founder
// intent becomes strategic intelligence. Additive only —
// reuses FIC/D14/D16/D17/D18/D19/IUC by reference (no FK).
// ============================================================

enum USFIPSessionState {
  OPEN
  INTERPRETING
  EXECUTING
  COMPLETED
  OVERRIDDEN
  ARCHIVED
}

enum USFIPProtocolStatus {
  DRAFT
  ACTIVE
  DEPRECATED
}

enum USFIPComponentStatus {
  ACTIVE
  INACTIVE
}

enum USFIPExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum StrategicPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum StrategicHorizon {
  IMMEDIATE
  SHORT
  MEDIUM
  LONG
}

model USFIPSession {
  id                   String            @id @default(cuid())
  usfipSessionId       String            @unique @default(cuid()) @map("usfip_session_id")
  name                 String
  description          String?
  workspaceId          String            @map("workspace_id")
  ownerId              String            @map("owner_id")
  state                USFIPSessionState @default(OPEN)
  founderDirective     String?           @map("founder_directive")
  strategicObjective   String?           @map("strategic_objective")
  strategicContext     String?           @map("strategic_context")
  strategicConstraints Json?             @map("strategic_constraints")
  strategicPriority    StrategicPriority @default(MEDIUM) @map("strategic_priority")
  strategicHorizon     StrategicHorizon  @default(MEDIUM) @map("strategic_horizon")
  strategicOutcome     String?           @map("strategic_outcome")
  intentReferenceId    String?           @map("intent_reference_id")
  intentReferenceType  String?           @map("intent_reference_type")
  overridden           Boolean           @default(false)
  executionSeq         Int               @default(0) @map("execution_seq")
  status               String            @default("ACTIVE")
  metadata             Json?
