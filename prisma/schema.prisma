model FounderIntent {
  id                      String                 @id @default(cuid())
  intentId                String                 @unique @default(cuid()) @map("intent_id")
  title                   String
  description             String
  rationale               String?
  constitutionalAuthority String                 @map("constitutional_authority")
  priority                FounderIntentPriority  @default(MEDIUM)
  ownerId                 String                 @map("owner_id")
  dependencies            String[]               @default([])
  affectedDomains         String[]               @default([]) @map("affected_domains")
  lifecycle               FounderIntentLifecycle @default(DRAFT)
  status                  String                 @default("DRAFT")
  version                 Int                    @default(1)
  majorVersion            Int                    @default(1) @map("major_version")
  minorVersion            Int                    @default(0) @map("minor_version")
  revisionVersion         Int                    @default(0) @map("revision_version")
  parentIntentId          String?                @map("parent_intent_id")
  supersededById          String?                @map("superseded_by_id")
  contentHash             String                 @map("content_hash")
  metadata                Json?                  @default("{}")
  workspaceId             String                 @map("workspace_id")
  createdById             String                 @map("created_by_id")
  createdAt               DateTime               @default(now()) @map("created_at")
  updatedAt               DateTime               @updatedAt @map("updated_at")
  deletedAt               DateTime?              @map("deleted_at")

  workspace            Workspace                   @relation(fields: [workspaceId], references: [id])
  parentIntent         FounderIntent?              @relation("FounderIntentParent", fields: [parentIntentId], references: [id])
  childIntents         FounderIntent[]             @relation("FounderIntentParent")
  supersededBy         FounderIntent?              @relation("FounderIntentSupersede", fields: [supersededById], references: [id])
  supersedes           FounderIntent[]             @relation("FounderIntentSupersede")
  versions             FounderIntentVersion[]
  relationshipsFrom    FounderIntentRelationship[] @relation("FounderIntentRelationSource")
  relationshipsTo      FounderIntentRelationship[] @relation("FounderIntentRelationTarget")
  reviews              FounderIntentReview[]
  conflicts            FounderIntentConflict[]     @relation("FounderIntentConflictPrimary")
  counterpartConflicts FounderIntentConflict[]     @relation("FounderIntentConflictCounterpart")
  overrideEvents       FounderOverrideEvent[]

  @@index([workspaceId, deletedAt, lifecycle])
  @@index([workspaceId, createdAt])
  @@index([parentIntentId])
  @@map("founder_intents")
}

model FounderIntentVersion {
  id            String                   @id @default(cuid())
  intentId      String                   @map("intent_id")
  versionNumber Int                      @map("version_number")
  versionType   FounderIntentVersionType @map("version_type")
  majorVersion  Int                      @map("major_version")
  minorVersion  Int                      @map("minor_version")
  revision      Int
  title         String
  description   String
  rationale     String?
  snapshot      Json
  diff          Json?
  changeSummary String?                  @map("change_summary")
  isActive      Boolean                  @default(false) @map("is_active")
  authorId      String                   @map("author_id")
  workspaceId   String                   @map("workspace_id")
  createdAt     DateTime                 @default(now()) @map("created_at")

  intent    FounderIntent @relation(fields: [intentId], references: [id])
  workspace Workspace     @relation(fields: [workspaceId], references: [id])

  @@unique([intentId, versionNumber])
  @@index([intentId, createdAt])
  @@index([workspaceId, createdAt])
  @@map("founder_intent_versions")
}

model FounderIntentRelationship {
  id             String                    @id @default(cuid())
  sourceIntentId String                    @map("source_intent_id")
  targetIntentId String                    @map("target_intent_id")
  relationType   FounderIntentRelationType @map("relation_type")
  notes          String?
  metadata       Json?                     @default("{}")
  workspaceId    String                    @map("workspace_id")
  createdById    String                    @map("created_by_id")
  createdAt      DateTime                  @default(now()) @map("created_at")
  deletedAt      DateTime?                 @map("deleted_at")

  sourceIntent FounderIntent @relation("FounderIntentRelationSource", fields: [sourceIntentId], references: [id])
  targetIntent FounderIntent @relation("FounderIntentRelationTarget", fields: [targetIntentId], references: [id])
  workspace    Workspace     @relation(fields: [workspaceId], references: [id])

  @@unique([sourceIntentId, targetIntentId, relationType], map: "founder_intent_relationships_src_tgt_type_key")
  @@index([workspaceId, createdAt])
  @@index([sourceIntentId])
  @@index([targetIntentId])
  @@map("founder_intent_relationships")
}

model FounderIntentReview {
  id                       String                      @id @default(cuid())
