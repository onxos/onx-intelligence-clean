// FILE: prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  status      UserStatus @default(ACTIVE)
  roleId      String   @map("role_id")
  workspaceId String   @map("workspace_id")
  tenantId    String   @map("tenant_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sessions    Session[]
  devices     Device[]
  evidence    EvidenceRecord[]
  intelligenceObjects IntelligenceObject[]
  governanceDecisions GovernanceDecision[]
  workspaceMembers WorkspaceMember[]

  role      Role      @relation(fields: [roleId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@map("users")
}

model Role {
  id          String @id @default(cuid())
  name        String @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions Permission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id        String   @id @default(cuid())
  resource  String
  action    String
  createdAt DateTime @default(now()) @map("created_at")

  roles Role[]

  @@unique([resource, action])
  @@map("permissions")
}

model Workspace {
  id          String @id @default(cuid())
  name        String
  description String?
  status      WorkspaceStatus @default(ACTIVE)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]
  intelligenceObjects IntelligenceObject[]
  evidence    EvidenceRecord[]
  providers   ProviderProfile[]
  tools       ToolProfile[]
  governanceDecisions GovernanceDecision[]
  capitalRecords CapitalRecord[]
  workspaceMembers WorkspaceMember[]

  @@map("workspaces")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("tenants")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  revokedAt DateTime? @map("revoked_at")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Device {
  id       String @id @default(cuid())
  name     String
  userId   String @map("user_id")
  lastSeen DateTime? @map("last_seen")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("devices")
}

model IntelligenceObject {
  id              String            @id @default(cuid())
  objectId        String            @unique @default(cuid()) @map("object_id")
  name            String
  content         String
  contentHash     String            @map("content_hash")
  semanticSummary String?           @map("semantic_summary")
  objectType      IntelligenceObjectType @map("object_type")
  layer           String            @default("L1_FOUNDATIONAL")
  originSource    String            @default("L2_SIL") @map("origin_source")
  creatorIdentity String            @default("system") @map("creator_identity")
  ownershipClass  OwnershipClass    @default(INSTITUTIONAL) @map("ownership_class")
  amanahScore     Float             @default(0.5) @map("amanah_score")
  confidenceScore Float             @default(0.5) @map("confidence_score")
  trustScore      Float             @default(0.5) @map("trust_score")
  qualityIndex    Float             @default(0.5) @map("quality_index")
  state           ObjectState       @default(ACTIVE)
  shadowStatus    ShadowStatus      @default(INTERNAL) @map("shadow_status")
  sourceLayer     String            @default("L1_FOUNDATIONAL") @map("source_layer")
  privacyLevel    PrivacyLevel      @default(INSTITUTIONAL) @map("privacy_level")
  ficValidated    Boolean           @default(false) @map("fic_validated")
  constraintBasis String?           @map("constraint_basis")
  capitalCategory CapitalCategory?  @map("capital_category")
  capitalValue    Float             @default(0) @map("capital_value")
  ownerId         String            @map("owner_id")
  creatorId       String            @map("creator_id")
  workspaceId     String            @map("workspace_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  owner         User   @relation(fields: [ownerId], references: [id])
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  evidence      EvidenceRecord[]
  provenance    ProvenanceRecord[]

  @@map("intelligence_objects")
}

model ProviderProfile {
  id             String @id @default(cuid())
  providerId     String @unique @map("provider_id")
  providerName   String @map("provider_name")
  status         ProviderStatus @default(ACTIVE)
  priority       Int    @default(1)
  domainFitness       Float @default(0) @map("domain_fitness")
  riskFitness         Float @default(0) @map("risk_fitness")
  historicalPerformance Float @default(0) @map("historical_performance")
  evidenceQuality     Float @default(0) @map("evidence_quality")
  judgmentQuality     Float @default(0) @map("judgment_quality")
  hallucinationResistance Float @default(0) @map("hallucination_resistance")
  governanceCompliance Float @default(0) @map("governance_compliance")
  costEfficiency      Float @default(0) @map("cost_efficiency")
  latency             Float @default(0)
  reliability         Float @default(0)
  outcomeSuccess      Float @default(0) @map("outcome_success")
  ownershipCompatibility Float @default(0) @map("ownership_compatibility")
  iseScore            Float @default(0) @map("ise_score")
  totalCapital        Float @default(0) @map("total_capital")
  models              String[]
  costPer1kTokens     Float @default(0) @map("cost_per_1k_tokens")
  latencyMs           Int    @default(0) @map("latency_ms")
  successRate         Float  @default(0) @map("success_rate")
  workspaceId         String @map("workspace_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  evaluations ProviderEvaluation[]

  @@map("provider_profiles")
}

model ProviderEvaluation {
  id        String   @id @default(cuid())
  providerId String  @map("provider_id")
  iseScore  Float   @map("ise_score")
  dimensions Json   @default("{}")
  intent    String
  context   String?
  createdAt DateTime @default(now()) @map("created_at")

  provider ProviderProfile @relation(fields: [providerId], references: [id])

  @@map("provider_evaluations")
}

model ToolProfile {
  id        String @id @default(cuid())
  toolId    String @unique @map("tool_id")
  toolName  String @map("tool_name")
  category  ToolCategory
  status    ToolStatus @default(ACTIVE)
  capabilities String[]
  costPerCall Float @default(0) @map("cost_per_call")
  totalCapital Float @default(0) @map("total_capital")
  workspaceId String @map("workspace_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@map("tool_profiles")
}

model EvidenceRecord {
  id        String   @id @default(cuid())
  evidenceId String  @unique @default(cuid()) @map("evidence_id")
  intent    String
  intelligenceObjectId String? @map("intelligence_object_id")
  ownerId   String   @map("owner_id")
  workspaceId String @map("workspace_id")
  confidence Float  @default(0)
  cost      Float   @default(0)
  latencyMs Int     @default(0) @map("latency_ms")
  evidenceQuality Float @default(0) @map("evidence_quality")
  capitalCreated Float @default(0) @map("capital_created")
  providerCandidates String[] @default([]) @map("provider_candidates")
  providerSelected String? @map("provider_selected")
  toolCandidates String[] @default([]) @map("tool_candidates")
  toolSelected String? @map("tool_selected")
  judgment  String?
  outcome   String?
  learning  String?
  createdAt DateTime @default(now()) @map("created_at")

  owner     User @relation(fields: [ownerId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  intelligenceObject IntelligenceObject? @relation(fields: [intelligenceObjectId], references: [id])

  @@map("evidence_records")
}

model GovernanceDecision {
  id           String @id @default(cuid())
  decisionType String @map("decision_type")
  outcome      String @default("UNDEFINED")
  amanahScore  Float @map("amanah_score")
  confidence   Float @default(0.5)
  ficValidated Boolean @default(false) @map("fic_validated")
  actorId      String @map("actor_id")
  workspaceId  String @map("workspace_id")
  createdAt    DateTime @default(now()) @map("created_at")

  actor     User @relation(fields: [actorId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@map("governance_decisions")
}

model CapitalRecord {
  id        String @id @default(cuid())
  type      String
  amount    Float
  category  CapitalCategory
  workspaceId String @map("workspace_id")
  ownerId   String @map("owner_id")
  sourceObjectId String? @map("source_object_id")
  createdAt DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@map("capital_records")
}

model ProvenanceRecord {
  id        String @id @default(cuid())
  action    String
  resource  String
  resourceId String? @map("resource_id")
  actorId   String @map("actor_id")
  workspaceId String? @map("workspace_id")
  oldValue  String? @map("old_value")
  newValue  String? @map("new_value")
  createdAt DateTime @default(now()) @map("created_at")

  intelligenceObject IntelligenceObject? @relation(fields: [resourceId], references: [id])

  @@map("provenance_records")
}

model FrontierAsset {
  id          String @id @default(cuid())
  assetId     String @unique @map("asset_id")
  name        String
  assetClass  String @map("asset_class")
  status      AssetStatus @default(CATALOGED)
  priorityScore Float @default(0) @map("priority_score")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("frontier_assets")
}

model SovereigntyMetric {
  id          String @id @default(cuid())
  metricType  String @map("metric_type")
  value       Float
  ksr         Float?
  pdr         Float?
  krr         Float?
  kor         Float?
  scg         Float?
  sai         Float?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("sovereignty_metrics")
}

model AuditLog {
  id          String   @id @default(cuid())
  eventId     String   @unique @map("event_id")
  timestamp   DateTime @default(now())
  action      String
  resource    String
  resourceType String  @map("resource_type")
  resourceId  String?  @map("resource_id")
  actorId     String   @map("actor_id")
  workspaceId String?  @map("workspace_id")
  oldValue    String?  @map("old_value")
  newValue    String?  @map("new_value")
  before      Json?
  after       Json?
  requestId   String?  @map("request_id")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  status      String   @default("SUCCESS")
  success     Boolean  @default(true)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([workspaceId, timestamp])
  @@index([actorId, timestamp])
  @@index([resourceType, timestamp])
  @@map("audit_logs")
}

model AIQueryLog {
  id           String   @id @default(cuid())
  queryId      String   @unique @map("query_id")
  workspaceId  String   @map("workspace_id")
  requesterId  String   @map("requester_id")
  query        String
  domain       String
  providerUsed String   @map("provider_used")
  modelUsed    String   @map("model_used")
  response     String?
  tokensUsed   Int      @map("tokens_used")
  latencyMs    Int      @map("latency_ms")
  evidenceTier String   @map("evidence_tier")
  ficStatus    String   @map("fic_status")
  ficCheckId   String?  @map("fic_check_id")
  sechRouteId  String?  @map("sech_route_id")
  iurgNodeId   String?  @map("iurg_node_id")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([createdAt])
  @@index([queryId])
  @@map("ai_query_logs")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum WorkspaceStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum TenantStatus {
  ACTIVE
  INACTIVE
}

enum IntelligenceObjectType {
  SIGNAL
  PATTERN
  JUDGMENT
  UNDERSTANDING
  WISDOM
  EXTERNAL_INTELLIGENCE
}

enum ObjectState {
  ACTIVE
  DORMANT
  DEPRECATED
  ARCHIVED
}

enum ShadowStatus {
  INTERNAL
  EXTERNAL
  HYBRID
}

enum OwnershipClass {
  PERSONAL
  COMPANION
  INSTITUTIONAL
  CIVILIZATION
}

enum PrivacyLevel {
  PUBLIC
  INSTITUTIONAL
  CONFIDENTIAL
  RESTRICTED
}

enum CapitalCategory {
  CLINICAL
  OPERATIONS
  COMMERCIAL
  STRATEGY
  GOVERNANCE
  KNOWLEDGE
}

enum ProviderStatus {
  ACTIVE
  INACTIVE
  EXPERIMENTAL
  DEPRECATED
}

enum ToolCategory {
  SEARCH
  ANALYTICS
  AUTOMATION
  COMMUNICATION
  KNOWLEDGE
  MEDIA
}

enum ToolStatus {
  ACTIVE
  INACTIVE
  EXPERIMENTAL
}

enum AssetStatus {
  CATALOGED
  READY
  OPERATIONAL
  RESEARCH
  DEPRECATED
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  userId      String   @map("user_id")
  role        String
  assignedBy  String?  @map("assigned_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_members")
}

model Plugin {
  id        String   @id
  name      String
  version   String
  type      String
  status    String
  config    Json     @default("{}")
  manifest  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("plugins")
}

model AgentLog {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  workspaceId String   @map("workspace_id")
  command     String
  action      String
  success     Boolean
  data        Json?
  error       String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([workspaceId])
  @@index([createdAt])
  @@map("agent_logs")
}

model Report {
  id          String   @id @default(cuid())
  title       String
  type        String
  workspaceId String   @map("workspace_id")
  createdBy   String   @map("created_by")
  data        Json?
  dateRange   String?  @map("date_range")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([createdAt])
  @@map("reports")
}

model Reminder {
  id            String   @id @default(cuid())
  type          String
  patientId     String   @map("patient_id")
  workspaceId   String   @map("workspace_id")
  scheduledDate DateTime @map("scheduled_date")
  status        String
  channel       String
  content       String
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([scheduledDate])
  @@index([status])
  @@map("reminders")
}

model Patient {
  id           String        @id @default(cuid())
  name         String
  species      String
  breed        String?
  age          Int?
  weight       Float?
  gender       Gender        @default(UNKNOWN)
  ownerName    String        @map("owner_name")
  ownerPhone   String?       @map("owner_phone")
  ownerEmail   String?       @map("owner_email")
  medicalNotes String?       @map("medical_notes")
  allergies    String[]      @default([])
  status       PatientStatus @default(ACTIVE)
  workspaceId  String        @map("workspace_id")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  appointments  Appointment[]
  prescriptions Prescription[]
  labResults    LabResult[]
  medicalRecords      MedicalRecord[]
  vaccinationRecords  VaccinationRecord[]
  clinicalDocuments   ClinicalDocument[]

  @@index([workspaceId])
  @@index([name])
  @@map("patients")
}

model Appointment {
  id             String            @id @default(cuid())
  patientId      String            @map("patient_id")
  title          String
  date           DateTime
  duration       Int               @default(30)
  status         AppointmentStatus @default(SCHEDULED)
  type           AppointmentType   @default(CHECKUP)
  notes          String?
  veterinarianId String?           @map("veterinarian_id")
  workspaceId    String            @map("workspace_id")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([workspaceId])
  @@index([patientId])
  @@index([date])
  @@index([status])
  @@map("appointments")
}

model Prescription {
  id           String              @id @default(cuid())
  patientId    String              @map("patient_id")
  medication   String
  dosage       String
  frequency    String
  duration     String
  instructions String?
  prescribedBy String              @map("prescribed_by")
  status       PrescriptionStatus  @default(ACTIVE)
  workspaceId  String              @map("workspace_id")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([workspaceId])
  @@index([patientId])
  @@map("prescriptions")
}

model LabResult {
  id                 String      @id @default(cuid())
  patientId          String      @map("patient_id")
  testName           String      @map("test_name")
  testCategory       LabCategory @default(BLOOD)
  value              String
  unit               String
  referenceRangeLow  String?     @map("reference_range_low")
  referenceRangeHigh String?     @map("reference_range_high")
  status             LabStatus   @default(PENDING)
  notes              String?
  testedBy           String      @map("tested_by")
  workspaceId        String      @map("workspace_id")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([workspaceId])
  @@index([patientId])
  @@index([testCategory])
  @@map("lab_results")
}

model MedicalRecord {
  id              String     @id @default(cuid())
  patientId       String     @map("patient_id")
  appointmentId   String?    @map("appointment_id")
  visitType       VisitType  @default(ROUTINE) @map("visit_type")
  chiefComplaint  String     @map("chief_complaint")
  symptoms        String[]   @default([])
  diagnosis       String?
  differentialDx  String?    @map("differential_dx")
  treatmentPlan   String?    @map("treatment_plan")
  notes           String?
  veterinarianId  String     @map("veterinarian_id")
  followUpDate    DateTime?  @map("follow_up_date")
  workspaceId     String     @map("workspace_id")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  patient     Patient     @relation(fields: [patientId], references: [id])
  documents   ClinicalDocument[]

  @@index([workspaceId])
  @@index([patientId])
  @@index([createdAt])
  @@map("medical_records")
}

model VaccinationRecord {
  id            String   @id @default(cuid())
  patientId     String   @map("patient_id")
  vaccineName   String   @map("vaccine_name")
  manufacturer  String?
  batchNumber   String?  @map("batch_number")
  administeredAt DateTime @map("administered_at")
  nextDueDate   DateTime @map("next_due_date")
  administeredBy String  @map("administered_by")
  notes         String?
  workspaceId   String   @map("workspace_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([workspaceId])
  @@index([patientId])
  @@index([nextDueDate])
  @@map("vaccination_records")
}

model ClinicalDocument {
  id               String       @id @default(cuid())
  patientId        String       @map("patient_id")
  medicalRecordId  String?      @map("medical_record_id")
  title            String
  documentType     DocumentType @default(OTHER) @map("document_type")
  fileUrl          String       @map("file_url")
  fileSize         Int?         @map("file_size")
  mimeType         String?      @map("mime_type")
  description      String?
  uploadedBy       String       @map("uploaded_by")
  workspaceId      String       @map("workspace_id")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  patient       Patient        @relation(fields: [patientId], references: [id])
  medicalRecord MedicalRecord? @relation(fields: [medicalRecordId], references: [id])

  @@index([workspaceId])
  @@index([patientId])
  @@index([documentType])
  @@map("clinical_documents")
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique @map("invoice_number")
  patientId     String        @map("patient_id")
  title         String
  description   String?
  subtotal      Float
  taxRate       Float         @default(0) @map("tax_rate")
  taxAmount     Float         @default(0) @map("tax_amount")
  discount      Float         @default(0)
  total         Float
  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime?     @map("due_date")
  paidAmount    Float         @default(0) @map("paid_amount")
  balance       Float
  notes         String?
  workspaceId   String        @map("workspace_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  items   InvoiceItem[]
  payments Payment[]

  @@index([workspaceId])
  @@index([patientId])
  @@index([status])
  @@index([invoiceNumber])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String  @map("invoice_id")
  description String
  quantity    Int     @default(1)
  unitPrice   Float   @map("unit_price")
  total       Float
  serviceType String? @map("service_type")
  workspaceId String  @map("workspace_id")
  createdAt   DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String        @map("invoice_id")
  amount        Float
  method        PaymentMethod @default(CASH)
  reference     String?
  paidAt        DateTime      @default(now()) @map("paid_at")
  notes         String?
  receivedBy    String        @map("received_by")
  workspaceId   String        @map("workspace_id")
  createdAt     DateTime      @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([invoiceId])
  @@map("payments")
}

model Product {
  id              String          @id @default(cuid())
  sku             String          @unique
  name            String
  description     String?
  category        ProductCategory @default(MEDICATION)
  subcategory     String?
  supplier        String?
  unitCost        Float           @map("unit_cost")
  sellingPrice    Float           @map("selling_price")
  quantityOnHand  Int             @default(0) @map("quantity_on_hand")
  quantityReserved Int            @default(0) @map("quantity_reserved")
  reorderLevel    Int             @default(10) @map("reorder_level")
  reorderQuantity Int             @default(50) @map("reorder_quantity")
  location        String?
  isActive        Boolean         @default(true) @map("is_active")
  expiryDate      DateTime?       @map("expiry_date")
  batchNumber     String?         @map("batch_number")
  workspaceId     String          @map("workspace_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  transactions InventoryTransaction[]

  @@index([workspaceId])
  @@index([category])
  @@index([sku])
  @@map("products")
}

model InventoryTransaction {
  id          String            @id @default(cuid())
  productId   String            @map("product_id")
  type        TransactionType
  quantity    Int
  unitCost    Float?            @map("unit_cost")
  totalCost   Float?            @map("total_cost")
  reference   String?
  notes       String?
  performedBy String            @map("performed_by")
  workspaceId String            @map("workspace_id")
  createdAt   DateTime          @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@index([workspaceId])
  @@index([productId])
  @@index([type])
  @@map("inventory_transactions")
}

model InventoryAlert {
  id          String     @id @default(cuid())
  productId   String     @map("product_id")
  productName String     @map("product_name")
  alertType   AlertType  @map("alert_type")
  severity    AlertSeverity @default(MEDIUM)
  message     String
  resolved    Boolean    @default(false)
  resolvedAt  DateTime?  @map("resolved_at")
  resolvedBy  String?    @map("resolved_by")
  workspaceId String     @map("workspace_id")
  createdAt   DateTime   @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([alertType])
  @@index([resolved])
  @@map("inventory_alerts")
}

model Notification {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  type        NotificationType
  title       String
  message     String
  data        Json?
  channel     String           @default("IN_APP")
  readAt      DateTime?        @map("read_at")
  sentAt      DateTime?        @map("sent_at")
  deliveredAt DateTime?        @map("delivered_at")
  workspaceId String           @map("workspace_id")
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([userId])
  @@index([type])
  @@index([readAt])
  @@map("notifications")
}

model ConnectorConfig {
  id            String          @id @default(cuid())
  name          String
  type          ConnectorType
  provider      String
  isActive      Boolean         @default(true) @map("is_active")
  credentials   Json            // encrypted API keys, tokens
  settings      Json?           // provider-specific settings
  webhookUrl    String?         @map("webhook_url")
  lastSyncAt    DateTime?       @map("last_sync_at")
  lastError     String?         @map("last_error")
  lastErrorAt   DateTime?       @map("last_error_at")
  workspaceId   String          @map("workspace_id")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  @@index([workspaceId])
  @@index([type])
  @@index([isActive])
  @@unique([workspaceId, name])
  @@map("connector_configs")
}

model ConnectorLog {
  id          String   @id @default(cuid())
  connectorId String   @map("connector_id")
  direction   String   // INBOUND / OUTBOUND
  action      String   // e.g., "send_message", "process_payment"
  status      String   // SUCCESS / FAILED / PENDING
  payload     Json?    // request/response payload (sanitized)
  error       String?
  durationMs  Int?     @map("duration_ms")
  workspaceId String   @map("workspace_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([connectorId])
  @@index([status])
  @@map("connector_logs")
}

