// ===========================================================================
// FIAR — Frontier Intelligence Asset Registry (Wave 12)
// Canonical inventory of every strategic Intelligence asset. Additive only.
// Reuses D16/FIC/USFIP/IFC/IUC/D17/D18/D19 by reference (no FK, no duplicated
// storage). NOT reasoning, planning, decision, platform.
// ===========================================================================

enum FIARAssetStatus {
  DRAFT
  ACTIVE
  DEPRECATED
  ARCHIVED
  REPLACED
  OVERRIDDEN
}

enum FIARAssetClass {
  KNOWLEDGE
  LEARNING
  MEMORY
  EVIDENCE
  INTENT
  CAPITAL
  MEASUREMENT
  RUNTIME
  EXCHANGE
  GOVERNANCE
  PROTOCOL
  MODEL
  TOOL
  PROVIDER
  REASONING
  PLANNING
  DECISION
}

enum FIARComponentStatus {
  ACTIVE
  INACTIVE
  DEPRECATED
}

enum FIAROwnershipKind {
  FOUNDER
  INSTITUTIONAL
  WORKSPACE
  DELEGATED
}

enum FIARRelationshipKind {
  DEPENDS_ON
  DERIVES_FROM
  REPLACES
  RELATES_TO
  COMPOSES
  REFERENCES
}

model FIARAsset {
  id                String          @id @default(cuid())
  fiarAssetId       String          @unique @default(cuid()) @map("fiar_asset_id")
  name              String
  description       String?
  workspaceId       String          @map("workspace_id")
  ownerId           String          @map("owner_id")
  assetClass        FIARAssetClass  @map("asset_class")
  status            FIARAssetStatus @default(DRAFT)
  version           Int             @default(1)
  sourceRuntime     String?         @map("source_runtime")
  referenceId       String?         @map("reference_id")
  referenceType     String?         @map("reference_type")
  constitutionalRef String?         @map("constitutional_ref")
  overridden        Boolean         @default(false)
  replacedById      String?         @map("replaced_by_id")
  historySeq        Int             @default(0) @map("history_seq")
  metadata          Json?
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  deletedAt         DateTime?       @map("deleted_at")

  workspace             Workspace            @relation(fields: [workspaceId], references: [id])
  classifications       FIARClassification[]
  ownerships            FIAROwnership[]
  relationships         FIARRelationship[]   @relation("FIARRelationshipSource")
  incomingRelationships FIARRelationship[]   @relation("FIARRelationshipTarget")
  history               FIARHistory[]
  evidence              FIAREvidence[]

  @@index([workspaceId, deletedAt, status])
  @@index([workspaceId, assetClass])
  @@index([workspaceId, createdAt])
  @@index([fiarAssetId])
  @@map("fiar_assets")
}

model FIARCategory {
  id                String              @id @default(cuid())
  categoryId        String              @unique @default(cuid()) @map("category_id")
  workspaceId       String              @map("workspace_id")
  name              String
  code              String
  description       String?
  assetClass        FIARAssetClass?     @map("asset_class")
  status            FIARComponentStatus @default(ACTIVE)
  constitutionalRef String?             @map("constitutional_ref")
  actorId           String              @map("actor_id")
  metadata          Json?
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  deletedAt         DateTime?           @map("deleted_at")

  workspace       Workspace            @relation(fields: [workspaceId], references: [id])
  classifications FIARClassification[]

  @@unique([workspaceId, code])
  @@index([workspaceId, status])
  @@index([categoryId])
  @@map("fiar_categories")
}

model FIARClassification {
  id                String         @id @default(cuid())
  classificationId  String         @unique @default(cuid()) @map("classification_id")
  assetId           String         @map("asset_id")
  workspaceId       String         @map("workspace_id")
  assetClass        FIARAssetClass @map("asset_class")
  categoryId        String?        @map("category_id")
