  NASCENT
  FORMING
  DEVELOPING
  ESTABLISHED
  INSTITUTIONALIZED
  EVOLVING
  DEPRECATED
}

enum UnderstandingEventType {
  STATE_TRANSITION
  PROGRESS_UPDATE
  EVIDENCE_LINKED
  CONFIDENCE_UPDATE
  EVOLUTION
}

enum UnderstandingRelationType {
  DEPENDS_ON
  SUPPORTS
  REFINES
  CONTRADICTS
  DERIVES_FROM
  GOVERNS
  COMPOSES
}

model IntelligenceCapital {
  id                String                      @id @default(cuid())
  capitalId         String                      @unique @default(cuid()) @map("capital_id")
  identity          String
  description       String?
  category          IntelligenceCapitalCategory
  ownerId           String                      @map("owner_id")
  workspaceId       String                      @map("workspace_id")
  currentValue      Float                       @default(0) @map("current_value")
  accumulatedValue  Float                       @default(0) @map("accumulated_value")
  allocatedValue    Float                       @default(0) @map("allocated_value")
  minimumValue      Float                       @default(0) @map("minimum_value")
  growthRate        Float                       @default(0) @map("growth_rate")
  preservationScore Float                       @default(1) @map("preservation_score")
  riskScore         Float                       @default(0) @map("risk_score")
  confidence        Float                       @default(0.5)
  sourceLineage     String[]                    @map("source_lineage")
  authority         AuthorityLevel              @default(OPERATIONAL)
  status            IntelligenceCapitalStatus   @default(ACTIVE)
  currency          String                      @default("IUC")
  metadata          Json?
  createdAt         DateTime                    @default(now()) @map("created_at")
  updatedAt         DateTime                    @updatedAt @map("updated_at")
  deletedAt         DateTime?                   @map("deleted_at")

  workspace          Workspace                  @relation(fields: [workspaceId], references: [id])
  accumulationEvents CapitalAccumulationEvent[]
  allocations        CapitalAllocation[]
  iucEntities        IUCEntity[]

  @@index([workspaceId, deletedAt, status])
  @@index([workspaceId, category, createdAt])
  @@index([capitalId])
  @@map("intelligence_capital")
}

model CapitalAccumulationEvent {
  id          String                  @id @default(cuid())
  capitalId   String                  @map("capital_id")
  eventType   CapitalAccumulationType @map("event_type")
  amount      Float                   @default(0)
  valueBefore Float                   @map("value_before")
  valueAfter  Float                   @map("value_after")
  reason      String?
  actorId     String                  @map("actor_id")
  workspaceId String                  @map("workspace_id")
  metadata    Json?
  createdAt   DateTime                @default(now()) @map("created_at")

  capital   IntelligenceCapital @relation(fields: [capitalId], references: [id])
  workspace Workspace           @relation(fields: [workspaceId], references: [id])

  @@index([capitalId, createdAt])
  @@index([workspaceId, eventType, createdAt])
  @@map("capital_accumulation_events")
}

model IUCEntity {
  id          String                 @id @default(cuid())
  iucId       String                 @unique @default(cuid()) @map("iuc_id")
  title       String
  description String?
  domain      String?
  ownerId     String                 @map("owner_id")
  workspaceId String                 @map("workspace_id")
  state       UnderstandingStateType @default(NASCENT)
  progress    Float                  @default(0)
  confidence  Float                  @default(0)
  authority   AuthorityLevel         @default(OPERATIONAL)
  capitalId   String?                @map("capital_id")
  status      String                 @default("ACTIVE")
  metadata    Json?
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")
  deletedAt   DateTime?              @map("deleted_at")

  workspace         Workspace                   @relation(fields: [workspaceId], references: [id])
  capital           IntelligenceCapital?        @relation(fields: [capitalId], references: [id])
  events            UnderstandingEvent[]
  evidence          UnderstandingEvidence[]
  outgoingRelations UnderstandingRelationship[] @relation("UnderstandingRelationSource")
  incomingRelations UnderstandingRelationship[] @relation("UnderstandingRelationTarget")

  @@index([workspaceId, deletedAt, state])
  @@index([workspaceId, domain, createdAt])
  @@index([iucId])
  @@map("iuc_entities")
}

model UnderstandingEvent {
  id               String                  @id @default(cuid())
  iucId            String                  @map("iuc_id")
  eventType        UnderstandingEventType  @map("event_type")
  fromState        UnderstandingStateType? @map("from_state")
  toState          UnderstandingStateType? @map("to_state")
  progressBefore   Float?                  @map("progress_before")
  progressAfter    Float?                  @map("progress_after")
  confidenceBefore Float?                  @map("confidence_before")
  confidenceAfter  Float?                  @map("confidence_after")
  actorId          String                  @map("actor_id")
  workspaceId      String                  @map("workspace_id")
  notes            String?
  metadata         Json?
  createdAt        DateTime                @default(now()) @map("created_at")

  iuc       IUCEntity @relation(fields: [iucId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([iucId, createdAt])
  @@index([workspaceId, eventType, createdAt])
  @@map("understanding_events")
}

model UnderstandingEvidence {
  id               String    @id @default(cuid())
  iucId            String    @map("iuc_id")
  evidenceRecordId String?   @map("evidence_record_id")
  objectId         String?   @map("object_id")
  description      String
  weight           Float     @default(1)
  actorId          String    @map("actor_id")
  workspaceId      String    @map("workspace_id")
  metadata         Json?
  createdAt        DateTime  @default(now()) @map("created_at")
  deletedAt        DateTime? @map("deleted_at")

  iuc       IUCEntity @relation(fields: [iucId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([iucId, deletedAt, createdAt])
  @@index([workspaceId, createdAt])
  @@map("understanding_evidence")
}

model UnderstandingRelationship {
  id           String                    @id @default(cuid())
  sourceIucId  String                    @map("source_iuc_id")
  targetIucId  String                    @map("target_iuc_id")
  relationType UnderstandingRelationType @map("relation_type")
  notes        String?
  metadata     Json?
  workspaceId  String                    @map("workspace_id")
  createdById  String                    @map("created_by_id")
  createdAt    DateTime                  @default(now()) @map("created_at")
  deletedAt    DateTime?                 @map("deleted_at")

  source    IUCEntity @relation("UnderstandingRelationSource", fields: [sourceIucId], references: [id])
  target    IUCEntity @relation("UnderstandingRelationTarget", fields: [targetIucId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([sourceIucId, targetIucId, relationType], map: "understanding_relationships_src_tgt_type_key")
  @@index([workspaceId, deletedAt, relationType])
  @@index([targetIucId])
  @@map("understanding_relationships")
}

// ---------------------------------------------------------------------------
// IW-08 — D17 Intelligence Measurement Architecture
// ---------------------------------------------------------------------------

enum MeasurementIndexType {
  UQI
  JQI
  WQI
  ICI
  OQI
  IRS
  CUSTOM
}

enum MeasurementProgressState {
  NASCENT
  GROWTH
  IMPROVEMENT
  PLATEAU
  REGRESSION
  STABLE
  COMPLETION
}

enum MeasurementTrend {
  UNKNOWN
  RISING
  FALLING
  STABLE
  VOLATILE
}

enum MeasurementFeedbackType {
  MEASUREMENT_UPDATE
  LEARNING_FEEDBACK
  CAPITAL_FEEDBACK
  KNOWLEDGE_FEEDBACK
  RECOMMENDATION
}

enum MeasurementFailureType {
  MEASUREMENT_FAILURE
  MISSING_EVIDENCE
  LOW_CONFIDENCE
  CONFLICT
  QUALITY_DEGRADATION
  CONSTITUTIONAL_VIOLATION
}

enum MeasurementHistoryEventType {
  PROFILE_CREATED
  PROFILE_UPDATED
  CALCULATED
  BENCHMARK_SET
  FEEDBACK_RECORDED
  FAILURE_RECORDED
  PROGRESS_TRANSITION
}

model MeasurementProfile {
  id                String                   @id @default(cuid())
  profileId         String                   @unique @default(cuid()) @map("profile_id")
  name              String
  description       String?
  indexType         MeasurementIndexType     @map("index_type")
  ownerId           String                   @map("owner_id")
  workspaceId       String                   @map("workspace_id")
  targetValue       Float                    @default(1) @map("target_value")
  minimumValue      Float                    @default(0) @map("minimum_value")
  weight            Float                    @default(1)
  normalizationMin  Float                    @default(0) @map("normalization_min")
  normalizationMax  Float                    @default(100) @map("normalization_max")
  currentScore      Float                    @default(0) @map("current_score")
  currentConfidence Float                    @default(0) @map("current_confidence")
  progressState     MeasurementProgressState @default(NASCENT) @map("progress_state")
  trend             MeasurementTrend         @default(UNKNOWN)
  authority         AuthorityLevel           @default(OPERATIONAL)
  status            String                   @default("ACTIVE")
  metadata          Json?
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")
  deletedAt         DateTime?                @map("deleted_at")

  workspace     Workspace              @relation(fields: [workspaceId], references: [id])
  records       MeasurementRecord[]
  historyEvents MeasurementHistory[]
  evidence      MeasurementEvidence[]
  benchmarks    MeasurementBenchmark[]
  feedback      MeasurementFeedback[]

  @@index([workspaceId, deletedAt, indexType])
  @@index([workspaceId, progressState, createdAt])
  @@index([profileId])
  @@map("measurement_profiles")
}

model MeasurementRecord {
  id              String                   @id @default(cuid())
  profileId       String                   @map("profile_id")
  rawScore        Float                    @map("raw_score")
  weightedScore   Float                    @map("weighted_score")
  normalizedScore Float                    @map("normalized_score")
  confidence      Float                    @default(0)
  delta           Float                    @default(0)
  benchmarkDelta  Float?                   @map("benchmark_delta")
  trend           MeasurementTrend         @default(UNKNOWN)
  progressState   MeasurementProgressState @default(NASCENT) @map("progress_state")
  components      Json?
  actorId         String                   @map("actor_id")
  workspaceId     String                   @map("workspace_id")
  metadata        Json?
  createdAt       DateTime                 @default(now()) @map("created_at")

  profile   MeasurementProfile @relation(fields: [profileId], references: [id])
  workspace Workspace          @relation(fields: [workspaceId], references: [id])

  @@index([profileId, createdAt])
  @@index([workspaceId, createdAt])
  @@map("measurement_records")
}

model MeasurementHistory {
  id               String                      @id @default(cuid())
  profileId        String                      @map("profile_id")
  recordId         String?                     @map("record_id")
  eventType        MeasurementHistoryEventType @map("event_type")
  scoreBefore      Float?                      @map("score_before")
  scoreAfter       Float?                      @map("score_after")
  confidenceBefore Float?                      @map("confidence_before")
  confidenceAfter  Float?                      @map("confidence_after")
  trend            MeasurementTrend?
  progressState    MeasurementProgressState?   @map("progress_state")
  failureType      MeasurementFailureType?     @map("failure_type")
  severity         String?
  actorId          String                      @map("actor_id")
  workspaceId      String                      @map("workspace_id")
  notes            String?
  metadata         Json?
  createdAt        DateTime                    @default(now()) @map("created_at")

  profile   MeasurementProfile @relation(fields: [profileId], references: [id])
  workspace Workspace          @relation(fields: [workspaceId], references: [id])

  @@index([profileId, createdAt])
  @@index([workspaceId, eventType, createdAt])
  @@index([workspaceId, failureType, createdAt])
  @@map("measurement_history")
}

model MeasurementEvidence {
  id               String    @id @default(cuid())
  profileId        String    @map("profile_id")
  recordId         String?   @map("record_id")
  evidenceRecordId String?   @map("evidence_record_id")
  objectId         String?   @map("object_id")
  description      String
  weight           Float     @default(1)
  actorId          String    @map("actor_id")
  workspaceId      String    @map("workspace_id")
  metadata         Json?
  createdAt        DateTime  @default(now()) @map("created_at")
  deletedAt        DateTime? @map("deleted_at")

  profile   MeasurementProfile @relation(fields: [profileId], references: [id])
  workspace Workspace          @relation(fields: [workspaceId], references: [id])

  @@index([profileId, deletedAt, createdAt])
  @@index([workspaceId, createdAt])
  @@map("measurement_evidence")
}

model MeasurementBenchmark {
  id          String    @id @default(cuid())
  profileId   String    @map("profile_id")
  name        String
  value       Float
  comparator  String    @default("GTE")
  source      String?
  actorId     String    @map("actor_id")
  workspaceId String    @map("workspace_id")
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

  profile   MeasurementProfile @relation(fields: [profileId], references: [id])
  workspace Workspace          @relation(fields: [workspaceId], references: [id])

  @@index([profileId, deletedAt, createdAt])
  @@map("measurement_benchmarks")
}

model MeasurementFeedback {
  id             String                  @id @default(cuid())
  profileId      String                  @map("profile_id")
  recordId       String?                 @map("record_id")
  feedbackType   MeasurementFeedbackType @map("feedback_type")
  targetType     String?                 @map("target_type")
  targetId       String?                 @map("target_id")
  recommendation String?
  payload        Json?
  actorId        String                  @map("actor_id")
  workspaceId    String                  @map("workspace_id")
  metadata       Json?
  createdAt      DateTime                @default(now()) @map("created_at")

  profile   MeasurementProfile @relation(fields: [profileId], references: [id])
  workspace Workspace          @relation(fields: [workspaceId], references: [id])

  @@index([profileId, createdAt])
  @@index([workspaceId, feedbackType, createdAt])
  @@map("measurement_feedback")
}

// ---------------------------------------------------------------------------
// IW-09 — D18 Intelligence Runtime Architecture
// Additive only. Build-only on D11/D12/D13/D16/FIC/IUC/D17. Backward compatible.
// ---------------------------------------------------------------------------

enum RuntimeSessionState {
  CREATED
  INITIALIZING
  READY
  RUNNING
  WAITING
  PAUSED
  RECOVERING
  DEGRADED
  FAILED
  STOPPING
  STOPPED
  ARCHIVED
}

enum RuntimeHealthStatus {
  UNKNOWN
  HEALTHY
  DEGRADED
  UNHEALTHY
}

enum RuntimeContextType {
  EXECUTION
  KNOWLEDGE
  LEARNING
  CAPITAL
  MEASUREMENT
  INTENT
  WORKSPACE
  PROVIDER
  MEMORY
}

enum RuntimeEventType {
  SESSION_CREATED
  STATE_TRANSITION
  CONTEXT_ATTACHED
  CHECKPOINT_CREATED
  CHECKPOINT_RESTORED
  SNAPSHOT_CREATED
  RECOVERY_STARTED
  RECOVERY_COMPLETED
  ROLLBACK
  HEARTBEAT
  RESUMED
  ERROR
}

enum RuntimeHistoryEventType {
  SESSION_CREATED
  STATE_TRANSITION
  CONTEXT_ATTACHED
  CHECKPOINT_CREATED
  CHECKPOINT_RESTORED
  SNAPSHOT_CREATED
  RECOVERY
  ROLLBACK
  POLICY_SET
  RESUMED
  HEALTH_CHECK
}

enum RuntimeCheckpointType {
  MANUAL
  AUTOMATIC
  PRE_RECOVERY
  PRE_ROLLBACK
  MILESTONE
}

enum RuntimeRecoveryType {
  CHECKPOINT_RESTORE
  RUNTIME_ROLLBACK
  CRASH_RECOVERY
  CONTINUITY_RECOVERY
  SESSION_RESUME
}

enum RuntimeRecoveryStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model RuntimeSession {
  id               String               @id @default(cuid())
  sessionId        String               @unique @default(cuid()) @map("session_id")
  name             String
  description      String?
  workspaceId      String               @map("workspace_id")
  ownerId          String               @map("owner_id")
  state            RuntimeSessionState  @default(CREATED)
  previousState    RuntimeSessionState? @map("previous_state")
  healthStatus     RuntimeHealthStatus  @default(UNKNOWN) @map("health_status")
  authority        AuthorityLevel       @default(OPERATIONAL)
  lineageRoot      String?              @map("lineage_root")
  parentSessionId  String?              @map("parent_session_id")
  continuitySeq    Int                  @default(0) @map("continuity_seq")
  eventSeq         Int                  @default(0) @map("event_seq")
  recoveryCount    Int                  @default(0) @map("recovery_count")
  lastCheckpointId String?              @map("last_checkpoint_id")
  lastHeartbeatAt  DateTime?            @map("last_heartbeat_at")
  stateEnteredAt   DateTime             @default(now()) @map("state_entered_at")
  status           String               @default("ACTIVE")
  metadata         Json?
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  deletedAt        DateTime?            @map("deleted_at")

  workspace     Workspace           @relation(fields: [workspaceId], references: [id])
  states        RuntimeState[]
  contexts      RuntimeContext[]
  events        RuntimeEvent[]
  checkpoints   RuntimeCheckpoint[]
  snapshots     RuntimeSnapshot[]
  recoveries    RuntimeRecovery[]
  historyEvents RuntimeHistory[]
  policies      RuntimePolicy[]

  @@index([workspaceId, deletedAt, state])
  @@index([workspaceId, healthStatus, createdAt])
  @@index([lineageRoot])
  @@index([sessionId])
  @@map("runtime_sessions")
}

model RuntimeState {
  id          String               @id @default(cuid())
  sessionId   String               @map("session_id")
  fromState   RuntimeSessionState? @map("from_state")
  toState     RuntimeSessionState  @map("to_state")
  reason      String?
  actorId     String               @map("actor_id")
  workspaceId String               @map("workspace_id")
  metadata    Json?
  createdAt   DateTime             @default(now()) @map("created_at")

  session   RuntimeSession @relation(fields: [sessionId], references: [id])
  workspace Workspace      @relation(fields: [workspaceId], references: [id])

  @@index([sessionId, createdAt])
  @@index([workspaceId, createdAt])
  @@map("runtime_states")
}

model RuntimeContext {
  id            String             @id @default(cuid())
  sessionId     String             @map("session_id")
  contextType   RuntimeContextType @map("context_type")
  key           String
  referenceId   String?            @map("reference_id")
  referenceType String?            @map("reference_type")
  payload       Json?
  version       Int                @default(1)
  active        Boolean            @default(true)
  actorId       String             @map("actor_id")
  workspaceId   String             @map("workspace_id")
  metadata      Json?
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  deletedAt     DateTime?          @map("deleted_at")

  session   RuntimeSession @relation(fields: [sessionId], references: [id])
  workspace Workspace      @relation(fields: [workspaceId], references: [id])

  @@index([sessionId, deletedAt, contextType])
  @@index([workspaceId, createdAt])
  @@map("runtime_contexts")
}

model RuntimeEvent {
  id          String               @id @default(cuid())
  sessionId   String               @map("session_id")
  eventType   RuntimeEventType     @map("event_type")
  sequence    Int
  state       RuntimeSessionState?
  description String?
  actorId     String               @map("actor_id")
  workspaceId String               @map("workspace_id")
  payload     Json?
  metadata    Json?
  createdAt   DateTime             @default(now()) @map("created_at")

  session   RuntimeSession @relation(fields: [sessionId], references: [id])
  workspace Workspace      @relation(fields: [workspaceId], references: [id])

  @@index([sessionId, sequence])
  @@index([workspaceId, eventType, createdAt])
  @@map("runtime_events")
}

model RuntimeCheckpoint {
  id              String                @id @default(cuid())
  checkpointId    String                @unique @default(cuid()) @map("checkpoint_id")
  sessionId       String                @map("session_id")
  checkpointType  RuntimeCheckpointType @default(MANUAL) @map("checkpoint_type")
  label           String
  sequence        Int
  capturedState   RuntimeSessionState   @map("captured_state")
  healthStatus    RuntimeHealthStatus   @default(UNKNOWN) @map("health_status")
  contextSnapshot Json?                 @map("context_snapshot")
  contextCount    Int                   @default(0) @map("context_count")
  actorId         String                @map("actor_id")
  workspaceId     String                @map("workspace_id")
  metadata        Json?
  createdAt       DateTime              @default(now()) @map("created_at")
  deletedAt       DateTime?             @map("deleted_at")

  session    RuntimeSession    @relation(fields: [sessionId], references: [id])
  workspace  Workspace         @relation(fields: [workspaceId], references: [id])
  recoveries RuntimeRecovery[]

  @@index([sessionId, deletedAt, sequence])
  @@index([workspaceId, createdAt])
  @@map("runtime_checkpoints")
}

model RuntimeSnapshot {
  id           String              @id @default(cuid())
  snapshotId   String              @unique @default(cuid()) @map("snapshot_id")
  sessionId    String              @map("session_id")
  checkpointId String?             @map("checkpoint_id")
  label        String
  state        RuntimeSessionState
  payload      Json
  contextCount Int                 @default(0) @map("context_count")
  actorId      String              @map("actor_id")
  workspaceId  String              @map("workspace_id")
  metadata     Json?
  createdAt    DateTime            @default(now()) @map("created_at")

  session   RuntimeSession @relation(fields: [sessionId], references: [id])
  workspace Workspace      @relation(fields: [workspaceId], references: [id])

  @@index([sessionId, createdAt])
  @@index([workspaceId, createdAt])
  @@map("runtime_snapshots")
}

model RuntimeRecovery {
  id           String                @id @default(cuid())
  recoveryId   String                @unique @default(cuid()) @map("recovery_id")
  sessionId    String                @map("session_id")
  checkpointId String?               @map("checkpoint_id")
  recoveryType RuntimeRecoveryType   @map("recovery_type")
  status       RuntimeRecoveryStatus @default(PENDING)
  fromState    RuntimeSessionState?  @map("from_state")
  toState      RuntimeSessionState?  @map("to_state")
  reason       String?
  success      Boolean               @default(false)
  actorId      String                @map("actor_id")
  workspaceId  String                @map("workspace_id")
  metadata     Json?
  createdAt    DateTime              @default(now()) @map("created_at")
  completedAt  DateTime?             @map("completed_at")

  session    RuntimeSession     @relation(fields: [sessionId], references: [id])
  workspace  Workspace          @relation(fields: [workspaceId], references: [id])
  checkpoint RuntimeCheckpoint? @relation(fields: [checkpointId], references: [id])

  @@index([sessionId, createdAt])
  @@index([workspaceId, recoveryType, createdAt])
  @@map("runtime_recoveries")
}

model RuntimeHistory {
  id           String                  @id @default(cuid())
  sessionId    String                  @map("session_id")
  eventType    RuntimeHistoryEventType @map("event_type")
  fromState    RuntimeSessionState?    @map("from_state")
  toState      RuntimeSessionState?    @map("to_state")
  healthStatus RuntimeHealthStatus?    @map("health_status")
  referenceId  String?                 @map("reference_id")
  actorId      String                  @map("actor_id")
  workspaceId  String                  @map("workspace_id")
  notes        String?
  metadata     Json?
  createdAt    DateTime                @default(now()) @map("created_at")

  session   RuntimeSession @relation(fields: [sessionId], references: [id])
  workspace Workspace      @relation(fields: [workspaceId], references: [id])

  @@index([sessionId, createdAt])
  @@index([workspaceId, eventType, createdAt])
  @@map("runtime_history")
}

model RuntimePolicy {
  id          String         @id @default(cuid())
  policyId    String         @unique @default(cuid()) @map("policy_id")
  sessionId   String         @map("session_id")
  name        String
  policyType  String         @map("policy_type")
  rules       Json?
  enabled     Boolean        @default(true)
  authority   AuthorityLevel @default(OPERATIONAL)
  actorId     String         @map("actor_id")
  workspaceId String         @map("workspace_id")
  metadata    Json?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  deletedAt   DateTime?      @map("deleted_at")

  session   RuntimeSession @relation(fields: [sessionId], references: [id])
  workspace Workspace      @relation(fields: [workspaceId], references: [id])

  @@index([sessionId, deletedAt])
  @@index([workspaceId, policyType, createdAt])
  @@map("runtime_policies")
}

// ============================================================================
// D19 — Intelligence Exchange Architecture (IW-10, Wave 7)
// Additive: constitutional Intelligence Exchange Layer. NOT platform/federation.
// ============================================================================

enum ExchangeSessionState {
  OPEN
  ACTIVE
  SUSPENDED
  CLOSED
  ARCHIVED
}

enum ExchangeStage {
  INTEND
  COMPREHEND
  VALIDATE
  TRANSFER
  VERIFY
  LINEAGE
  MEASURE
  CAPITALIZE
  COMPLETE
  FAILED
}

enum ExchangeTransactionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  ROLLED_BACK
  REPLAYED
}

enum ExchangeOwnershipClass {
  FOUNDER
  WORKSPACE
  AGENT
  RUNTIME
  KNOWLEDGE
  CAPITAL
  SHARED
}

enum ExchangeVerificationState {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum ExchangeValidationState {
  PENDING
  PASSED
  FAILED
}

enum ExchangeMessageType {
  REQUEST
  RESPONSE
  EVENT
  RECEIPT
  ERROR
}

enum ExchangeReceiptStatus {
  ISSUED
  ACKNOWLEDGED
  REJECTED
}

enum ExchangeAuditOutcome {
  PASS
  FAIL
  WARN
}

enum ExchangeEventType {
  SESSION_CREATED
  SESSION_UPDATED
  TRANSACTION_CREATED
  STAGE_ADVANCED
  MESSAGE_SENT
  ENVELOPE_SEALED
  RECEIPT_ISSUED
  VALIDATED
  TRANSFERRED
  VERIFIED
  LINEAGE_RECORDED
  MEASURED
  CAPITALIZED
  COMPLETED
  FAILED
  ROLLED_BACK
  REPLAYED
  POLICY_SET
}

model ExchangeSession {
  id             String                 @id @default(cuid())
  exchangeId     String                 @unique @default(cuid()) @map("exchange_id")
  name           String
  description    String?
  workspaceId    String                 @map("workspace_id")
  ownerId        String                 @map("owner_id")
  ownershipClass ExchangeOwnershipClass @default(WORKSPACE) @map("ownership_class")
  state          ExchangeSessionState   @default(OPEN)
  authority      AuthorityLevel         @default(OPERATIONAL)
  transactionSeq Int                    @default(0) @map("transaction_seq")
  eventSeq       Int                    @default(0) @map("event_seq")
  status         String                 @default("ACTIVE")
  metadata       Json?
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  deletedAt      DateTime?              @map("deleted_at")

  workspace     Workspace             @relation(fields: [workspaceId], references: [id])
  transactions  ExchangeTransaction[]
  envelopes     ExchangeEnvelope[]
  messages      ExchangeMessage[]
  receipts      ExchangeReceipt[]
  audits        ExchangeAudit[]
  historyEvents ExchangeHistory[]
  policies      ExchangePolicy[]
  lineages      ExchangeLineage[]
  contexts      ExchangeContext[]

  @@index([workspaceId, deletedAt, state])
  @@index([workspaceId, createdAt])
  @@index([exchangeId])
  @@map("exchange_sessions")
}

model ExchangeTransaction {
  id                  String                    @id @default(cuid())
  transactionId       String                    @unique @default(cuid()) @map("transaction_id")
  sessionId           String                    @map("session_id")
  workspaceId         String                    @map("workspace_id")
  ownerId             String                    @map("owner_id")
  intent              String
  description         String?
  stage               ExchangeStage             @default(INTEND)
  previousStage       ExchangeStage?            @map("previous_stage")
  status              ExchangeTransactionStatus @default(PENDING)
  ownershipClass      ExchangeOwnershipClass    @default(WORKSPACE) @map("ownership_class")
  origin              String?
  destination         String?
  parentTransactionId String?                   @map("parent_transaction_id")
  sourceObjectId      String?                   @map("source_object_id")
  sourceObjectType    String?                   @map("source_object_type")
  targetObjectId      String?                   @map("target_object_id")
  targetObjectType    String?                   @map("target_object_type")
  authority           AuthorityLevel            @default(OPERATIONAL)
  confidence          Float                     @default(0)
  verification        ExchangeVerificationState @default(UNVERIFIED)
  provenance          String?
  integrityHash       String?                   @map("integrity_hash")
  integrityVerified   Boolean                   @default(false) @map("integrity_verified")
  traceable           Boolean                   @default(true)
  trustScore          Float                     @default(0) @map("trust_score")
  validationState     ExchangeValidationState   @default(PENDING) @map("validation_state")
  stageSeq            Int                       @default(0) @map("stage_seq")
  eventSeq            Int                       @default(0) @map("event_seq")
  replayCount         Int                       @default(0) @map("replay_count")
  rolledBack          Boolean                   @default(false) @map("rolled_back")
  completedAt         DateTime?                 @map("completed_at")
  metadata            Json?
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")
  deletedAt           DateTime?                 @map("deleted_at")

  session       ExchangeSession    @relation(fields: [sessionId], references: [id])
  workspace     Workspace          @relation(fields: [workspaceId], references: [id])
  envelopes     ExchangeEnvelope[]
  messages      ExchangeMessage[]
  receipts      ExchangeReceipt[]
  audits        ExchangeAudit[]
  historyEvents ExchangeHistory[]
  lineages      ExchangeLineage[]
  contexts      ExchangeContext[]

  @@index([sessionId, deletedAt, stage])
  @@index([workspaceId, deletedAt, stage])
  @@index([workspaceId, status, createdAt])
  @@index([parentTransactionId])
  @@index([transactionId])
  @@map("exchange_transactions")
}

model ExchangeEnvelope {
  id             String                 @id @default(cuid())
  envelopeId     String                 @unique @default(cuid()) @map("envelope_id")
  transactionId  String                 @map("transaction_id")
  sessionId      String                 @map("session_id")
  workspaceId    String                 @map("workspace_id")
  payload        Json
  contentType    String                 @default("application/json") @map("content_type")
  checksum       String
  sealed         Boolean                @default(true)
  ownershipClass ExchangeOwnershipClass @default(WORKSPACE) @map("ownership_class")
  authority      AuthorityLevel         @default(OPERATIONAL)
  actorId        String                 @map("actor_id")
  metadata       Json?
  sealedAt       DateTime               @default(now()) @map("sealed_at")
  createdAt      DateTime               @default(now()) @map("created_at")

  transaction ExchangeTransaction @relation(fields: [transactionId], references: [id])
  session     ExchangeSession     @relation(fields: [sessionId], references: [id])
  workspace   Workspace           @relation(fields: [workspaceId], references: [id])

  @@index([transactionId, createdAt])
  @@index([workspaceId, createdAt])
  @@map("exchange_envelopes")
}

model ExchangeMessage {
  id            String              @id @default(cuid())
  messageId     String              @unique @default(cuid()) @map("message_id")
  transactionId String              @map("transaction_id")
  sessionId     String              @map("session_id")
  workspaceId   String              @map("workspace_id")
  messageType   ExchangeMessageType @map("message_type")
  sequence      Int
  stage         ExchangeStage
  fromParty     String?             @map("from_party")
  toParty       String?             @map("to_party")
  body          String?
  payload       Json?
  actorId       String              @map("actor_id")
  metadata      Json?
  createdAt     DateTime            @default(now()) @map("created_at")

  transaction ExchangeTransaction @relation(fields: [transactionId], references: [id])
  session     ExchangeSession     @relation(fields: [sessionId], references: [id])
  workspace   Workspace           @relation(fields: [workspaceId], references: [id])

  @@index([transactionId, sequence])
  @@index([workspaceId, createdAt])
  @@map("exchange_messages")
}

model ExchangeReceipt {
  id            String                    @id @default(cuid())
  receiptId     String                    @unique @default(cuid()) @map("receipt_id")
  transactionId String                    @map("transaction_id")
  sessionId     String                    @map("session_id")
  workspaceId   String                    @map("workspace_id")
  status        ExchangeReceiptStatus     @default(ISSUED)
  stage         ExchangeStage
  trustScore    Float                     @default(0) @map("trust_score")
  verification  ExchangeVerificationState @default(UNVERIFIED)
  issuedTo      String?                   @map("issued_to")
  notes         String?
  actorId       String                    @map("actor_id")
  metadata      Json?
  createdAt     DateTime                  @default(now()) @map("created_at")

  transaction ExchangeTransaction @relation(fields: [transactionId], references: [id])
  session     ExchangeSession     @relation(fields: [sessionId], references: [id])
  workspace   Workspace           @relation(fields: [workspaceId], references: [id])

  @@index([transactionId, createdAt])
  @@index([workspaceId, createdAt])
  @@map("exchange_receipts")
}

model ExchangeAudit {
  id            String               @id @default(cuid())
  auditId       String               @unique @default(cuid()) @map("audit_id")
  transactionId String               @map("transaction_id")
  sessionId     String               @map("session_id")
  workspaceId   String               @map("workspace_id")
  dimension     String
  outcome       ExchangeAuditOutcome
  stage         ExchangeStage?
  detail        String?
  score         Float?
  actorId       String               @map("actor_id")
  metadata      Json?
  createdAt     DateTime             @default(now()) @map("created_at")

  transaction ExchangeTransaction @relation(fields: [transactionId], references: [id])
  session     ExchangeSession     @relation(fields: [sessionId], references: [id])
  workspace   Workspace           @relation(fields: [workspaceId], references: [id])

  @@index([transactionId, createdAt])
  @@index([workspaceId, dimension, createdAt])
  @@map("exchange_audits")
}

model ExchangeHistory {
  id            String            @id @default(cuid())
  transactionId String?           @map("transaction_id")
  sessionId     String            @map("session_id")
  workspaceId   String            @map("workspace_id")
  eventType     ExchangeEventType @map("event_type")
  fromStage     ExchangeStage?    @map("from_stage")
  toStage       ExchangeStage?    @map("to_stage")
  referenceId   String?           @map("reference_id")
  notes         String?
  actorId       String            @map("actor_id")
  metadata      Json?
  createdAt     DateTime          @default(now()) @map("created_at")

  transaction ExchangeTransaction? @relation(fields: [transactionId], references: [id])
  session     ExchangeSession      @relation(fields: [sessionId], references: [id])
  workspace   Workspace            @relation(fields: [workspaceId], references: [id])

  @@index([sessionId, createdAt])
  @@index([transactionId, createdAt])
  @@index([workspaceId, eventType, createdAt])
  @@map("exchange_history")
}

model ExchangePolicy {
  id          String         @id @default(cuid())
  policyId    String         @unique @default(cuid()) @map("policy_id")
  sessionId   String         @map("session_id")
  workspaceId String         @map("workspace_id")
  name        String
  policyType  String         @map("policy_type")
  rules       Json?
  enabled     Boolean        @default(true)
  authority   AuthorityLevel @default(OPERATIONAL)
  actorId     String         @map("actor_id")
  metadata    Json?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  deletedAt   DateTime?      @map("deleted_at")

  session   ExchangeSession @relation(fields: [sessionId], references: [id])
  workspace Workspace       @relation(fields: [workspaceId], references: [id])

  @@index([sessionId, deletedAt])
  @@index([workspaceId, policyType, createdAt])
  @@map("exchange_policies")
}

model ExchangeLineage {
  id                  String   @id @default(cuid())
  lineageId           String   @unique @default(cuid()) @map("lineage_id")
  transactionId       String   @map("transaction_id")
  sessionId           String   @map("session_id")
  workspaceId         String   @map("workspace_id")
  origin              String?
  destination         String?
  parentTransactionId String?  @map("parent_transaction_id")
  childTransactionId  String?  @map("child_transaction_id")
  sourceObjectId      String?  @map("source_object_id")
  sourceObjectType    String?  @map("source_object_type")
  targetObjectId      String?  @map("target_object_id")
  targetObjectType    String?  @map("target_object_type")
  executionChain      Json?    @map("execution_chain")
  depth               Int      @default(0)
  actorId             String   @map("actor_id")
  metadata            Json?
  createdAt           DateTime @default(now()) @map("created_at")

  transaction ExchangeTransaction @relation(fields: [transactionId], references: [id])
  session     ExchangeSession     @relation(fields: [sessionId], references: [id])
  workspace   Workspace           @relation(fields: [workspaceId], references: [id])

  @@index([transactionId, createdAt])
  @@index([parentTransactionId])
  @@index([workspaceId, createdAt])
  @@map("exchange_lineage")
}

model ExchangeContext {
  id            String    @id @default(cuid())
  contextId     String    @unique @default(cuid()) @map("context_id")
  sessionId     String    @map("session_id")
  transactionId String?   @map("transaction_id")
  workspaceId   String    @map("workspace_id")
  contextType   String    @map("context_type")
  key           String
  referenceId   String?   @map("reference_id")
  referenceType String?   @map("reference_type")
  payload       Json?
  version       Int       @default(1)
  active        Boolean   @default(true)
  actorId       String    @map("actor_id")
  metadata      Json?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  session     ExchangeSession      @relation(fields: [sessionId], references: [id])
  workspace   Workspace            @relation(fields: [workspaceId], references: [id])
  transaction ExchangeTransaction? @relation(fields: [transactionId], references: [id])

  @@index([sessionId, deletedAt, contextType])
  @@index([workspaceId, createdAt])
  @@map("exchange_contexts")
}

// ============================================================================
// IW-11 — D15 Proof & Stress Architecture
// Constitutional verification + resilience layer. Additive only.
// Cross-domain integration via plain String references (no cross-domain FKs).
// ============================================================================

enum ProofSessionState {
  OPEN
  ACTIVE
  CERTIFIED
  FAILED
  ARCHIVED
}

enum ProofExecutionStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
  ERROR
}

enum CertificationGate {
  KNOWLEDGE_INTEGRITY
  MEMORY_INTEGRITY
  RUNTIME_INTEGRITY
  EXCHANGE_INTEGRITY
  CAPITAL_INTEGRITY
  MEASUREMENT_INTEGRITY
  GOVERNANCE_INTEGRITY
  AUDIT_INTEGRITY
  EVIDENCE_INTEGRITY
  SECURITY_INTEGRITY
}

enum CertificationOutcome {
  PASS
  WARNING
  FAIL
  CRITICAL
}

enum ProofFindingSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProofScenarioGroup {
  KNOWLEDGE
  LEARNING
  RUNTIME
  EXCHANGE
  CAPITAL
  MEASUREMENT
  GOVERNANCE
  SECURITY
  RECOVERY
}

enum FailureInjectionType {
  MISSING_KNOWLEDGE
  CORRUPTED_MEMORY
  INVALID_EXCHANGE
  AUTHORITY_VIOLATION
  TRUST_FAILURE
  EVIDENCE_LOSS
  RUNTIME_INTERRUPTION
  RECOVERY_FAILURE
  STATE_CORRUPTION
  MEASUREMENT_INCONSISTENCY
}

enum FailureInjectionStatus {
  INJECTED
  DETECTED
  CONTAINED
  RECOVERED
  UNRECOVERED
}

enum ContradictionType {
  KNOWLEDGE
  INTENT
  CAPITAL
  MEASUREMENT
  RUNTIME
  GOVERNANCE
}

enum ContradictionSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum StressCampaignState {
  OPEN
  RUNNING
  COMPLETED
  FAILED
  ARCHIVED
}

enum StressExecutionStatus {
  PENDING
  RUNNING
  PASSED
  DEGRADED
  FAILED
}

enum RecoveryStatus {
  PENDING
  RECOVERED
  PARTIAL
  FAILED
}

model ProofSession {
  id                   String                @id @default(cuid())
  proofSessionId       String                @unique @default(cuid()) @map("proof_session_id")
  name                 String
  description          String?
  workspaceId          String                @map("workspace_id")
  ownerId              String                @map("owner_id")
  state                ProofSessionState     @default(OPEN)
  scope                String?
  targetDomain         String?               @map("target_domain")
  certificationOutcome CertificationOutcome? @map("certification_outcome")
  certificationScore   Float                 @default(0) @map("certification_score")
  scenarioSeq          Int                   @default(0) @map("scenario_seq")
  eventSeq             Int                   @default(0) @map("event_seq")
  status               String                @default("ACTIVE")
  metadata             Json?
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  deletedAt            DateTime?             @map("deleted_at")

  workspace      Workspace            @relation(fields: [workspaceId], references: [id])
  scenarios      ProofScenario[]
  executions     ProofExecution[]
  results        ProofResult[]
  evidence       ProofEvidence[]
  findings       ProofFinding[]
  certifications ProofCertification[]
  history        ProofHistory[]

  @@index([workspaceId, deletedAt, state])
  @@index([workspaceId, createdAt])
  @@index([proofSessionId])
  @@map("proof_sessions")
}

model ProofScenario {
  id          String             @id @default(cuid())
  scenarioId  String             @unique @default(cuid()) @map("scenario_id")
  sessionId   String             @map("session_id")
  workspaceId String             @map("workspace_id")
  name        String
  description String?
  group       ProofScenarioGroup
  gate        CertificationGate?
  version     Int                @default(1)
  definition  Json?
  expectation Json?
  repeatable  Boolean            @default(true)
  enabled     Boolean            @default(true)
  actorId     String             @map("actor_id")
  metadata    Json?
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  deletedAt   DateTime?          @map("deleted_at")

  session    ProofSession     @relation(fields: [sessionId], references: [id])
  workspace  Workspace        @relation(fields: [workspaceId], references: [id])
  executions ProofExecution[]

  @@index([sessionId, deletedAt, group])
  @@index([workspaceId, createdAt])
  @@index([scenarioId])
  @@map("proof_scenarios")
}

model ProofExecution {
  id          String                @id @default(cuid())
  executionId String                @unique @default(cuid()) @map("execution_id")
  sessionId   String                @map("session_id")
  scenarioId  String?               @map("scenario_id")
  workspaceId String                @map("workspace_id")
  gate        CertificationGate?
  status      ProofExecutionStatus  @default(PENDING)
  outcome     CertificationOutcome?
  score       Float                 @default(0)
  durationMs  Int                   @default(0) @map("duration_ms")
  detail      String?
  actorId     String                @map("actor_id")
  startedAt   DateTime              @default(now()) @map("started_at")
  completedAt DateTime?             @map("completed_at")
  metadata    Json?
  createdAt   DateTime              @default(now()) @map("created_at")

  session   ProofSession    @relation(fields: [sessionId], references: [id])
  scenario  ProofScenario?  @relation(fields: [scenarioId], references: [id])
  workspace Workspace       @relation(fields: [workspaceId], references: [id])
  results   ProofResult[]
  evidence  ProofEvidence[]
  findings  ProofFinding[]

  @@index([sessionId, createdAt])
  @@index([workspaceId, status])
  @@index([executionId])
  @@map("proof_executions")
}

model ProofResult {
  id          String               @id @default(cuid())
  resultId    String               @unique @default(cuid()) @map("result_id")
  executionId String               @map("execution_id")
  sessionId   String               @map("session_id")
  workspaceId String               @map("workspace_id")
  gate        CertificationGate
  outcome     CertificationOutcome
  score       Float                @default(0)
  expected    String?
  actual      String?
  detail      String?
  actorId     String               @map("actor_id")
  metadata    Json?
  createdAt   DateTime             @default(now()) @map("created_at")

  execution ProofExecution @relation(fields: [executionId], references: [id])
  session   ProofSession   @relation(fields: [sessionId], references: [id])
  workspace Workspace      @relation(fields: [workspaceId], references: [id])

  @@index([executionId])
  @@index([workspaceId, gate])
  @@map("proof_results")
}

model ProofEvidence {
  id            String   @id @default(cuid())
  evidenceId    String   @unique @default(cuid()) @map("evidence_id")
  sessionId     String   @map("session_id")
  executionId   String?  @map("execution_id")
  workspaceId   String   @map("workspace_id")
  evidenceType  String   @map("evidence_type")
  referenceId   String?  @map("reference_id")
  referenceType String?  @map("reference_type")
  summary       String?
  payload       Json?
  actorId       String   @map("actor_id")
  createdAt     DateTime @default(now()) @map("created_at")

  session   ProofSession    @relation(fields: [sessionId], references: [id])
  execution ProofExecution? @relation(fields: [executionId], references: [id])
  workspace Workspace       @relation(fields: [workspaceId], references: [id])

  @@index([sessionId, createdAt])
  @@index([workspaceId, evidenceType])
  @@map("proof_evidence")
}

model ProofFinding {
  id                 String               @id @default(cuid())
  findingId          String               @unique @default(cuid()) @map("finding_id")
  sessionId          String               @map("session_id")
  executionId        String?              @map("execution_id")
  workspaceId        String               @map("workspace_id")
  severity           ProofFindingSeverity @default(INFO)
  gate               CertificationGate?
  title              String
  detail             String?
  recommendation     String?
  constitutionalRefs Json?                @map("constitutional_refs")
  resolved           Boolean              @default(false)
  actorId            String               @map("actor_id")
  metadata           Json?
  createdAt          DateTime             @default(now()) @map("created_at")

  session   ProofSession    @relation(fields: [sessionId], references: [id])
  execution ProofExecution? @relation(fields: [executionId], references: [id])
  workspace Workspace       @relation(fields: [workspaceId], references: [id])

  @@index([sessionId, createdAt])
  @@index([workspaceId, severity])
  @@index([findingId])
  @@map("proof_findings")
}

model ProofCertification {
  id              String               @id @default(cuid())
  certificationId String               @unique @default(cuid()) @map("certification_id")
  sessionId       String               @map("session_id")
  workspaceId     String               @map("workspace_id")
  gate            CertificationGate
  outcome         CertificationOutcome
  score           Float                @default(0)
  summary         String?
  evidenceRef     String?              @map("evidence_ref")
  validUntil      DateTime?            @map("valid_until")
  actorId         String               @map("actor_id")
  metadata        Json?
  createdAt       DateTime             @default(now()) @map("created_at")

  session   ProofSession @relation(fields: [sessionId], references: [id])
  workspace Workspace    @relation(fields: [workspaceId], references: [id])

  @@index([sessionId, createdAt])
  @@index([workspaceId, gate])
  @@index([certificationId])
  @@map("proof_certifications")
}

model ProofHistory {
  id          String   @id @default(cuid())
  sessionId   String   @map("session_id")
  executionId String?  @map("execution_id")
  workspaceId String   @map("workspace_id")
  eventType   String   @map("event_type")
  referenceId String?  @map("reference_id")
  notes       String?
  actorId     String   @map("actor_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  session   ProofSession @relation(fields: [sessionId], references: [id])
  workspace Workspace    @relation(fields: [workspaceId], references: [id])

  @@index([sessionId, createdAt])
  @@index([workspaceId, eventType])
  @@map("proof_history")
}

model StressCampaign {
  id              String              @id @default(cuid())
  campaignId      String              @unique @default(cuid()) @map("campaign_id")
  name            String
  description     String?
  workspaceId     String              @map("workspace_id")
  ownerId         String              @map("owner_id")
  state           StressCampaignState @default(OPEN)
  group           ProofScenarioGroup?
  targetDomain    String?             @map("target_domain")
  scenarioSeq     Int                 @default(0) @map("scenario_seq")
  eventSeq        Int                 @default(0) @map("event_seq")
  resilienceScore Float               @default(0) @map("resilience_score")
  status          String              @default("ACTIVE")
  metadata        Json?
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  deletedAt       DateTime?           @map("deleted_at")

  workspace  Workspace          @relation(fields: [workspaceId], references: [id])
  scenarios  StressScenario[]
  executions StressExecution[]
  injections FailureInjection[]
  results    StressResult[]
  evidence   StressEvidence[]
  history    StressHistory[]

  @@index([workspaceId, deletedAt, state])
  @@index([workspaceId, createdAt])
  @@index([campaignId])
  @@map("stress_campaigns")
}

model StressScenario {
  id            String                @id @default(cuid())
  scenarioId    String                @unique @default(cuid()) @map("scenario_id")
  campaignId    String                @map("campaign_id")
  workspaceId   String                @map("workspace_id")
  name          String
  description   String?
  group         ProofScenarioGroup
  injectionType FailureInjectionType? @map("injection_type")
  version       Int                   @default(1)
  definition    Json?
  repeatable    Boolean               @default(true)
  enabled       Boolean               @default(true)
  actorId       String                @map("actor_id")
  metadata      Json?
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  deletedAt     DateTime?             @map("deleted_at")

  campaign   StressCampaign    @relation(fields: [campaignId], references: [id])
  workspace  Workspace         @relation(fields: [workspaceId], references: [id])
  executions StressExecution[]

  @@index([campaignId, deletedAt, group])
  @@index([workspaceId, createdAt])
  @@index([scenarioId])
  @@map("stress_scenarios")
}

model StressExecution {
  id              String                @id @default(cuid())
  executionId     String                @unique @default(cuid()) @map("execution_id")
  campaignId      String                @map("campaign_id")
  scenarioId      String?               @map("scenario_id")
  workspaceId     String                @map("workspace_id")
  status          StressExecutionStatus @default(PENDING)
  outcome         CertificationOutcome?
  resilienceScore Float                 @default(0) @map("resilience_score")
  injectionsCount Int                   @default(0) @map("injections_count")
  recoveredCount  Int                   @default(0) @map("recovered_count")
  durationMs      Int                   @default(0) @map("duration_ms")
  detail          String?
  actorId         String                @map("actor_id")
  startedAt       DateTime              @default(now()) @map("started_at")
  completedAt     DateTime?             @map("completed_at")
  metadata        Json?
  createdAt       DateTime              @default(now()) @map("created_at")

  campaign         StressCampaign     @relation(fields: [campaignId], references: [id])
  scenario         StressScenario?    @relation(fields: [scenarioId], references: [id])
  workspace        Workspace          @relation(fields: [workspaceId], references: [id])
  injections       FailureInjection[]
  results          StressResult[]
  evidence         StressEvidence[]
  recoveryEvidence RecoveryEvidence[]

  @@index([campaignId, createdAt])
  @@index([workspaceId, status])
  @@index([executionId])
  @@map("stress_executions")
}

model FailureInjection {
  id                  String                 @id @default(cuid())
  injectionId         String                 @unique @default(cuid()) @map("injection_id")
  executionId         String                 @map("execution_id")
  campaignId          String                 @map("campaign_id")
  workspaceId         String                 @map("workspace_id")
  injectionType       FailureInjectionType   @map("injection_type")
  status              FailureInjectionStatus @default(INJECTED)
  targetReferenceId   String?                @map("target_reference_id")
  targetReferenceType String?                @map("target_reference_type")
  detected            Boolean                @default(false)
  contained           Boolean                @default(false)
  recovered           Boolean                @default(false)
  detail              String?
  actorId             String                 @map("actor_id")
  injectedAt          DateTime               @default(now()) @map("injected_at")
  resolvedAt          DateTime?              @map("resolved_at")
  metadata            Json?
  createdAt           DateTime               @default(now()) @map("created_at")

  execution        StressExecution    @relation(fields: [executionId], references: [id])
  campaign         StressCampaign     @relation(fields: [campaignId], references: [id])
  workspace        Workspace          @relation(fields: [workspaceId], references: [id])
  recoveryEvidence RecoveryEvidence[]

  @@index([executionId])
  @@index([workspaceId, injectionType])
  @@index([injectionId])
  @@map("failure_injections")
}

model StressResult {
  id          String               @id @default(cuid())
  resultId    String               @unique @default(cuid()) @map("result_id")
  executionId String               @map("execution_id")
  campaignId  String               @map("campaign_id")
  workspaceId String               @map("workspace_id")
  dimension   String
  outcome     CertificationOutcome
  score       Float                @default(0)
  detail      String?
  actorId     String               @map("actor_id")
  metadata    Json?
  createdAt   DateTime             @default(now()) @map("created_at")

  execution StressExecution @relation(fields: [executionId], references: [id])
  campaign  StressCampaign  @relation(fields: [campaignId], references: [id])
  workspace Workspace       @relation(fields: [workspaceId], references: [id])

  @@index([executionId])
  @@index([workspaceId, dimension])
  @@map("stress_results")
}

model StressEvidence {
  id            String   @id @default(cuid())
  evidenceId    String   @unique @default(cuid()) @map("evidence_id")
  campaignId    String   @map("campaign_id")
  executionId   String?  @map("execution_id")
  workspaceId   String   @map("workspace_id")
  evidenceType  String   @map("evidence_type")
  referenceId   String?  @map("reference_id")
  referenceType String?  @map("reference_type")
  summary       String?
  payload       Json?
  actorId       String   @map("actor_id")
  createdAt     DateTime @default(now()) @map("created_at")

  campaign  StressCampaign   @relation(fields: [campaignId], references: [id])
  execution StressExecution? @relation(fields: [executionId], references: [id])
  workspace Workspace        @relation(fields: [workspaceId], references: [id])

  @@index([campaignId, createdAt])
  @@index([workspaceId, evidenceType])
  @@map("stress_evidence")
}

model RecoveryEvidence {
  id          String         @id @default(cuid())
  recoveryId  String         @unique @default(cuid()) @map("recovery_id")
  executionId String         @map("execution_id")
  injectionId String?        @map("injection_id")
  campaignId  String         @map("campaign_id")
  workspaceId String         @map("workspace_id")
  status      RecoveryStatus @default(PENDING)
  strategy    String?
  durationMs  Int            @default(0) @map("duration_ms")
  detail      String?
  actorId     String         @map("actor_id")
  metadata    Json?
  createdAt   DateTime       @default(now()) @map("created_at")

  execution StressExecution   @relation(fields: [executionId], references: [id])
  injection FailureInjection? @relation(fields: [injectionId], references: [id])
  workspace Workspace         @relation(fields: [workspaceId], references: [id])

  @@index([executionId])
  @@index([workspaceId, status])
  @@index([recoveryId])
  @@map("recovery_evidence")
}

model StressHistory {
  id          String   @id @default(cuid())
  campaignId  String   @map("campaign_id")
  executionId String?  @map("execution_id")
  workspaceId String   @map("workspace_id")
  eventType   String   @map("event_type")
  referenceId String?  @map("reference_id")
  notes       String?
  actorId     String   @map("actor_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  campaign  StressCampaign @relation(fields: [campaignId], references: [id])
  workspace Workspace      @relation(fields: [workspaceId], references: [id])

  @@index([campaignId, createdAt])
  @@index([workspaceId, eventType])
  @@map("stress_history")
}

model Contradiction {
  id                 String                @id @default(cuid())
  contradictionId    String                @unique @default(cuid()) @map("contradiction_id")
  workspaceId        String                @map("workspace_id")
  sessionId          String?               @map("session_id")
  executionId        String?               @map("execution_id")
  type               ContradictionType
  severity           ContradictionSeverity @default(LOW)
  impact             String?
  recommendedAction  String?               @map("recommended_action")
  constitutionalRefs Json?                 @map("constitutional_refs")
  leftReferenceId    String?               @map("left_reference_id")
  leftReferenceType  String?               @map("left_reference_type")
  rightReferenceId   String?               @map("right_reference_id")
  rightReferenceType String?               @map("right_reference_type")
  detail             String?
  resolved           Boolean               @default(false)
  actorId            String                @map("actor_id")
  metadata           Json?
  createdAt          DateTime              @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([workspaceId, type])
  @@index([contradictionId])
  @@map("contradictions")
}

