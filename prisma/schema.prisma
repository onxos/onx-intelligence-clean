model IFCProfile {
  id                 String           @id @default(cuid())
  ifcProfileId       String           @unique @default(cuid()) @map("ifc_profile_id")
  name               String
  description        String?
  workspaceId        String           @map("workspace_id")
  ownerId            String           @map("owner_id")
  status             IFCProfileStatus @default(DRAFT)
  flourishingIndex   Float            @default(0) @map("flourishing_index")
  confidence         Float            @default(0)
  trend              IFCTrend         @default(STABLE)
  risk               IFCRiskLevel     @default(LOW)
  degraded           Boolean          @default(false)
  overridden         Boolean          @default(false)
  intentReferenceId  String?          @map("intent_reference_id")
  objectiveReference String?          @map("objective_reference")
  constitutionalRef  String?          @map("constitutional_ref")
  scoreSeq           Int              @default(0) @map("score_seq")
  metadata           Json?
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  deletedAt          DateTime?        @map("deleted_at")

  workspace  Workspace      @relation(fields: [workspaceId], references: [id])
  dimensions IFCDimension[]
  indicators IFCIndicator[]
  scores     IFCScore[]
  signals    IFCSignal[]
  history    IFCHistory[]
  evidence   IFCEvidence[]

  @@index([workspaceId, deletedAt, status])
  @@index([workspaceId, createdAt])
  @@index([ifcProfileId])
  @@map("ifc_profiles")
}

